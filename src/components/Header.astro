---
import { Menu, BookOpen, Home, Users, GraduationCap, Camera, PhoneCall, ChevronRight } from '@lucide/astro';

const menuItems = [
  { href: "/", label: "Beranda", icon: Home },
  { href: "/tentang", label: "Tentang Kami", icon: Users },
  { href: "/kurikulum", label: "Kurikulum", icon: GraduationCap },
  { href: "/kehidupan-asrama", label: "Kehidupan Asrama", icon: BookOpen },
  { href: "/galeri", label: "Galeri Kegiatan", icon: Camera },
  { href: "/kontak", label: "Hubungi Kami", icon: PhoneCall }
];
---
<header id="header" class="fixed top-0 left-0 right-0 z-40 bg-transparent transition-all duration-300 py-4 is-top">
    <div class="max-w-7xl mx-auto px-6 md:px-12 flex items-center justify-between">
        
        <!-- Logo -->
        <a href="/" class="flex items-center gap-3 z-50">
            <div class="w-10 h-10 rounded-full bg-primary flex items-center justify-center border border-border/30 shadow-md">
                <BookOpen class="w-5 h-5 text-white" />
            </div>
            <span class="font-heading font-semibold text-xl text-primary">Lin Nisa'</span>
        </a>

        <!-- Desktop Nav -->
        <nav class="hidden lg:flex items-center gap-8">
            <a href="/" class="nav-link text-sm font-medium text-text-dark hover:text-gold transition-colors">Beranda</a>
            <a href="/tentang" class="nav-link text-sm font-medium text-text-dark hover:text-gold transition-colors">Tentang Kami</a>
            <a href="/kurikulum" class="nav-link text-sm font-medium text-text-dark hover:text-gold transition-colors">Kurikulum</a>
            <a href="/kehidupan-asrama" class="nav-link text-sm font-medium text-text-dark hover:text-gold transition-colors">Kehidupan Asrama</a>
            <a href="/galeri" class="nav-link text-sm font-medium text-text-dark hover:text-gold transition-colors">Galeri</a>
            <a href="/kontak" class="nav-link text-sm font-medium text-text-dark hover:text-gold transition-colors">Hubungi Kami</a>
        </nav>

        <!-- CTA & Mobile Toggle -->
        <div class="flex items-center gap-4 z-50">
            <a id="nav-ppdb-btn" href="/#ppdb" class="hidden md:inline-flex items-center justify-center px-6 py-2.5 rounded-full bg-primary text-white text-sm font-medium hover:bg-primary/90 transition-all shadow-md hover:shadow-lg transform hover:-translate-y-0.5">
                Daftar PPDB
            </a>
            <button id="mobile-menu-btn" class="lg:hidden p-2 text-primary focus:outline-none transition-colors cursor-pointer" aria-label="Toggle Menu">
                <Menu id="menu-icon-svg" class="w-6 h-6 transition-transform" />
            </button>
        </div>
    </div>

    <!-- Backdrop Overlay for Mobile Drawer Menu -->
    <div id="mobile-menu-backdrop" class="fixed inset-0 bg-primary/40 backdrop-blur-sm z-30 opacity-0 pointer-events-none transition-opacity duration-300 lg:hidden"></div>

    <!-- Mobile Slide-over Drawer Menu -->
    <div id="mobile-menu" class="fixed inset-y-0 right-0 w-[80%] max-w-[340px] bg-white z-40 transform translate-x-full transition-transform duration-300 lg:hidden flex flex-col justify-between border-l border-border/50 shadow-2xl">
        <!-- Header inside Menu -->
        <div class="p-6 border-b border-border/20 flex items-center justify-between">
            <div class="flex items-center gap-2.5">
                <div class="w-8 h-8 rounded-full bg-primary/10 flex items-center justify-center text-primary">
                    <BookOpen class="w-4 h-4" />
                </div>
                <span class="font-heading font-bold text-lg text-primary">Menu Pondok</span>
            </div>
            <!-- Small label -->
            <span class="text-[10px] uppercase tracking-wider font-bold text-gold bg-gold/10 px-2 py-0.5 rounded-full border border-gold/15">Lin Nisa'</span>
        </div>

        <!-- Body Menu (iOS settings-like List) -->
        <div class="flex-grow overflow-y-auto py-4">
            <div class="space-y-1">
                {menuItems.map((item) => {
                    const IconComponent = item.icon;
                    return (
                        <a href={item.href} class="mobile-link flex items-center justify-between py-4 px-6 hover:bg-background transition-all group border-b border-border/10">
                            <div class="flex items-center gap-4">
                                <div class="w-9 h-9 rounded-xl bg-background border border-border/30 flex items-center justify-center text-muted group-hover:bg-primary/10 group-hover:text-primary transition-colors">
                                    <IconComponent class="w-4 h-4" />
                                </div>
                                <span class="text-sm font-semibold text-primary/95 group-hover:text-primary transition-colors">{item.label}</span>
                            </div>
                            <ChevronRight class="w-4 h-4 text-muted/60 group-hover:text-primary group-hover:translate-x-0.5 transition-all" />
                        </a>
                    );
                })}
            </div>
        </div>

        <!-- Footer inside Menu -->
        <div class="p-6 border-t border-border/20 bg-background/50">
            <p class="text-[10px] uppercase font-bold text-muted tracking-widest mb-3">Informasi Kontak</p>
            <div class="space-y-2 mb-6">
                <a href="tel:+6281234567890" class="flex items-center gap-2.5 text-xs text-muted hover:text-primary transition-colors">
                    <span class="w-2.5 h-2.5 rounded-full bg-gold/30"></span> +62 812 3456 7890
                </a>
                <span class="flex items-start gap-2.5 text-xs text-muted leading-relaxed">
                    <span class="w-2.5 h-2.5 rounded-full bg-primary/30 mt-1"></span> Pujon, Kab. Malang, Jawa Timur
                </span>
            </div>
            
            <a href="/#ppdb" class="mobile-link w-full inline-flex items-center justify-center py-3 rounded-xl bg-primary text-white text-xs font-bold hover:bg-primary/90 transition-all shadow-md text-center">
                Daftar PPDB Santri Baru
            </a>
        </div>
    </div>
</header>
