---
import { Menu, BookOpen, Home, Users, GraduationCap, Camera, PhoneCall, ChevronRight } from '@lucide/astro';
import Logo from './Logo.astro';

const menuItems = [
  { href: "/", label: "Beranda", icon: Home },
  { href: "/tentang", label: "Tentang Kami", icon: Users },
  { href: "/kurikulum", label: "Kurikulum", icon: GraduationCap },
  { href: "/kehidupan-asrama", label: "Kehidupan Asrama", icon: BookOpen },
  { href: "/galeri", label: "Galeri Kegiatan", icon: Camera },
  { href: "/kontak", label: "Hubungi Kami", icon: PhoneCall }
];
---
<header id="header" class="fixed top-0 left-0 right-0 z-40 bg-transparent transition-all duration-300 py-4 is-top">
    <!-- Top Navigation Bar Container -->
    <div class="max-w-7xl mx-auto px-6 md:px-12 flex items-center justify-between relative z-50">
        
        <!-- Logo -->
        <a href="/" class="flex items-center gap-2.5 shrink-0">
            <Logo className="w-10 h-10 shrink-0" />
            <div class="flex flex-col leading-none font-heading logo-text text-white transition-colors duration-300">
                <span class="text-[9px] md:text-[11px] font-semibold tracking-widest text-gold uppercase mb-0.5">Ma'had Nurul Haromain</span>
                <span class="text-sm md:text-base font-bold tracking-wide">Lin Nisa'</span>
            </div>
        </a>

        <!-- Desktop Nav -->
        <nav class="hidden lg:flex items-center lg:gap-5 xl:gap-8">
            <a href="/" class="nav-link lg:text-xs xl:text-sm font-medium text-white/80 hover:text-white transition-colors duration-300">Beranda</a>
            <a href="/tentang" class="nav-link lg:text-xs xl:text-sm font-medium text-white/80 hover:text-white transition-colors duration-300">Tentang Kami</a>
            <a href="/kurikulum" class="nav-link lg:text-xs xl:text-sm font-medium text-white/80 hover:text-white transition-colors duration-300">Kurikulum</a>
            <a href="/kehidupan-asrama" class="nav-link lg:text-xs xl:text-sm font-medium text-white/80 hover:text-white transition-colors duration-300">Kehidupan Asrama</a>
            <a href="/galeri" class="nav-link lg:text-xs xl:text-sm font-medium text-white/80 hover:text-white transition-colors duration-300">Galeri</a>
            <a href="/kontak" class="nav-link lg:text-xs xl:text-sm font-medium text-white/80 hover:text-white transition-colors duration-300">Hubungi Kami</a>
        </nav>

        <!-- CTA & Mobile Toggle -->
        <div class="flex items-center gap-4">
            <a id="nav-ppdb-btn" href="/#ppdb" class="hidden md:inline-flex items-center justify-center px-6 py-2.5 rounded-full bg-primary text-white text-sm font-medium hover:bg-primary/90 transition-all shadow-md hover:shadow-lg transform hover:-translate-y-0.5">
                Daftar PPDB
            </a>
            <button id="mobile-menu-btn" class="lg:hidden p-2 text-white focus:outline-none cursor-pointer transition-colors duration-300" aria-label="Toggle Menu">
                <Menu id="menu-icon-svg" class="w-6 h-6 transition-transform" />
            </button>
        </div>
    </div>

    <!-- Backdrop Overlay for Mobile Dropdown Menu -->
    <div id="mobile-menu-backdrop" class="fixed inset-0 bg-primary/40 backdrop-blur-sm z-30 opacity-0 pointer-events-none transition-opacity duration-300 lg:hidden"></div>

    <!-- Mobile Dropdown Menu (Top-to-Bottom Modal Dropdown) -->
    <div id="mobile-menu" class="fixed top-0 left-0 right-0 bg-white z-40 transform -translate-y-full transition-transform duration-500 lg:hidden flex flex-col justify-between border-b border-border/20 shadow-2xl pt-24 pb-8 max-h-[95vh] overflow-y-auto scrollbar-none">
        <!-- Body Menu (Premium Dashboard-like list) -->
        <div class="py-2">
            <div class="space-y-0.5">
                {menuItems.map((item) => {
                    const IconComponent = item.icon;
                    return (
                        <a href={item.href} class="mobile-link flex items-center justify-between py-4 px-6 hover:bg-primary/5 transition-all duration-300 group border-l-4 border-transparent hover:border-primary border-b border-border/5">
                            <div class="flex items-center gap-4">
                                <div class="w-10 h-10 rounded-xl bg-gray-50 border border-border/10 flex items-center justify-center text-muted group-hover:bg-primary/10 group-hover:text-primary transition-all duration-300">
                                    <IconComponent class="w-4 h-4" />
                                </div>
                                <span class="text-[15px] font-semibold text-text-dark group-hover:text-primary transition-colors duration-300">{item.label}</span>
                            </div>
                            <ChevronRight class="w-4 h-4 text-muted/50 group-hover:text-primary group-hover:translate-x-1 transition-all duration-300" />
                        </a>
                    );
                })}
            </div>
        </div>

        <!-- Footer inside Menu -->
        <div class="p-5 border-t border-border/10 bg-background/50">
            <div class="flex gap-3 w-full">
                <button id="close-menu-btn-inner" class="flex-1 inline-flex items-center justify-center py-3 px-4 rounded-xl bg-gray-100 hover:bg-gray-200 text-primary text-xs font-bold transition-all text-center cursor-pointer">
                    Tutup Menu
                </button>
                <a href="/#ppdb" class="mobile-link flex-1 inline-flex items-center justify-center py-3 px-4 rounded-xl bg-primary text-white text-xs font-bold hover:bg-primary/90 transition-all shadow-md text-center shrink-0">
                    Daftar PPDB
                </a>
            </div>
        </div>
    </div>
</header>
