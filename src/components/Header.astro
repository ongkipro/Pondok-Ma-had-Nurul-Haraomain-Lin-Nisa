---
import { Menu, BookOpen, Home, Users, GraduationCap, Camera, PhoneCall, ChevronRight } from '@lucide/astro';
import Logo from './Logo.astro';

const menuItems = [
  { href: "/", label: "Beranda", icon: Home },
  { href: "/tentang", label: "Tentang Kami", icon: Users },
  { href: "/kurikulum", label: "Kurikulum", icon: GraduationCap },
  { href: "/kehidupan-asrama", label: "Kehidupan Asrama", icon: BookOpen },
  { href: "/galeri", label: "Galeri Kegiatan", icon: Camera },
  { href: "/kontak", label: "Hubungi Kami", icon: PhoneCall }
];
---
<header id="header" class="fixed top-0 left-0 right-0 z-40 bg-transparent transition-all duration-300 py-4 is-top">
    <!-- Top Navigation Bar Container -->
    <div class="max-w-7xl mx-auto px-6 md:px-12 flex items-center justify-between relative z-50">
        
        <!-- Logo -->
        <a href="/" class="flex items-center gap-3">
            <Logo className="w-10 h-10" />
            <span class="font-heading font-semibold text-xl text-white logo-text transition-colors duration-300">Lin Nisa'</span>
        </a>

        <!-- Desktop Nav -->
        <nav class="hidden lg:flex items-center gap-8">
            <a href="/" class="nav-link text-sm font-medium text-white/80 hover:text-white transition-colors duration-300">Beranda</a>
            <a href="/tentang" class="nav-link text-sm font-medium text-white/80 hover:text-white transition-colors duration-300">Tentang Kami</a>
            <a href="/kurikulum" class="nav-link text-sm font-medium text-white/80 hover:text-white transition-colors duration-300">Kurikulum</a>
            <a href="/kehidupan-asrama" class="nav-link text-sm font-medium text-white/80 hover:text-white transition-colors duration-300">Kehidupan Asrama</a>
            <a href="/galeri" class="nav-link text-sm font-medium text-white/80 hover:text-white transition-colors duration-300">Galeri</a>
            <a href="/kontak" class="nav-link text-sm font-medium text-white/80 hover:text-white transition-colors duration-300">Hubungi Kami</a>
        </nav>

        <!-- CTA & Mobile Toggle -->
        <div class="flex items-center gap-4">
            <a id="nav-ppdb-btn" href="/#ppdb" class="hidden md:inline-flex items-center justify-center px-6 py-2.5 rounded-full bg-primary text-white text-sm font-medium hover:bg-primary/90 transition-all shadow-md hover:shadow-lg transform hover:-translate-y-0.5">
                Daftar PPDB
            </a>
            <button id="mobile-menu-btn" class="lg:hidden p-2 text-white focus:outline-none cursor-pointer transition-colors duration-300" aria-label="Toggle Menu">
                <Menu id="menu-icon-svg" class="w-6 h-6 transition-transform" />
            </button>
        </div>
    </div>

    <!-- Backdrop Overlay for Mobile Dropdown Menu -->
    <div id="mobile-menu-backdrop" class="fixed inset-0 bg-primary/40 backdrop-blur-sm z-30 opacity-0 pointer-events-none transition-opacity duration-300 lg:hidden"></div>

    <!-- Mobile Dropdown Menu (Top-to-Bottom Modal Dropdown) -->
    <div id="mobile-menu" class="fixed top-0 left-0 right-0 bg-white z-40 transform -translate-y-full transition-transform duration-500 lg:hidden flex flex-col justify-between border-b border-border/20 shadow-2xl pt-24 pb-8 max-h-[90vh] overflow-y-auto">
        <!-- Body Menu (iOS settings-like List) -->
        <div class="py-2">
            <div class="space-y-1">
                {menuItems.map((item) => {
                    const IconComponent = item.icon;
                    return (
                        <a href={item.href} class="mobile-link flex items-center justify-between py-3.5 px-6 hover:bg-background transition-all group border-b border-border/10">
                            <div class="flex items-center gap-4">
                                <div class="w-9 h-9 rounded-xl bg-background border border-border/30 flex items-center justify-center text-muted group-hover:bg-primary/10 group-hover:text-primary transition-colors">
                                    <IconComponent class="w-4 h-4" />
                                </div>
                                <span class="text-sm font-semibold text-primary/95 group-hover:text-primary transition-colors">{item.label}</span>
                            </div>
                            <ChevronRight class="w-4 h-4 text-muted/60 group-hover:text-primary group-hover:translate-x-0.5 transition-all" />
                        </a>
                    );
                })}
            </div>
        </div>

        <!-- Footer inside Menu -->
        <div class="p-6 border-t border-border/10 bg-background/50">
            <div class="flex flex-col sm:flex-row sm:justify-between sm:items-center gap-4">
                <div>
                    <p class="text-[10px] uppercase font-bold text-muted tracking-widest mb-2">Informasi Kontak</p>
                    <div class="flex flex-wrap gap-x-6 gap-y-1">
                        <a href="tel:+6281234567890" class="text-xs text-muted hover:text-primary transition-colors">
                            +62 812 3456 7890
                        </a>
                        <span class="text-xs text-muted leading-relaxed">
                            Pujon, Kab. Malang, Jawa Timur
                        </span>
                    </div>
                </div>
                <div class="flex gap-3 w-full sm:w-auto mt-2 sm:mt-0">
                    <button id="close-menu-btn-inner" class="flex-1 sm:flex-none inline-flex items-center justify-center py-3 px-6 rounded-xl bg-gray-100 hover:bg-gray-200 text-primary text-xs font-bold transition-all text-center cursor-pointer">
                        Tutup
                    </button>
                    <a href="/#ppdb" class="mobile-link flex-1 sm:flex-none inline-flex items-center justify-center py-3 px-6 rounded-xl bg-primary text-white text-xs font-bold hover:bg-primary/90 transition-all shadow-md text-center shrink-0">
                        Daftar PPDB
                    </a>
                </div>
            </div>
        </div>
    </div>
</header>
