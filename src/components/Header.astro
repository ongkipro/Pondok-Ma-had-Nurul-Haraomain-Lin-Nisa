---
import { BookOpen, Menu } from '@lucide/astro';
---
<header id="header" class="fixed w-full top-0 z-50 transition-all duration-300 bg-transparent py-4 is-top">
    <div class="max-w-7xl mx-auto px-6 md:px-12 flex justify-between items-center">
        <!-- Logo -->
        <a href="#" class="flex items-center gap-3 z-50">
            <div class="w-10 h-10 rounded-full bg-primary flex items-center justify-center border-2 border-gold/50 shadow-sm border-gold/30">
                <BookOpen class="w-5 h-5 text-gold" />
            </div>
            <span class="font-heading font-semibold text-xl text-primary tracking-wide hidden sm:block logo-text transition-colors">Nurul Haromain</span>
        </a>

        <!-- Desktop Nav -->
        <nav class="hidden lg:flex items-center gap-8">
            <a href="/" class="nav-link text-sm font-medium text-text-dark hover:text-gold transition-colors">Beranda</a>
            <a href="/tentang" class="nav-link text-sm font-medium text-text-dark hover:text-gold transition-colors">Tentang Kami</a>
            <a href="/kurikulum" class="nav-link text-sm font-medium text-text-dark hover:text-gold transition-colors">Kurikulum</a>
            <a href="/kehidupan-asrama" class="nav-link text-sm font-medium text-text-dark hover:text-gold transition-colors">Kehidupan Asrama</a>
            <a href="/galeri" class="nav-link text-sm font-medium text-text-dark hover:text-gold transition-colors">Galeri</a>
            <a href="/kontak" class="nav-link text-sm font-medium text-text-dark hover:text-gold transition-colors">Hubungi Kami</a>
        </nav>

        <!-- CTA & Mobile Toggle -->
        <div class="flex items-center gap-4 z-50">
            <a id="nav-ppdb-btn" href="/#ppdb" class="hidden md:inline-flex items-center justify-center px-6 py-2.5 rounded-full bg-primary text-white text-sm font-medium hover:bg-primary/90 transition-all shadow-md hover:shadow-lg transform hover:-translate-y-0.5">
                Daftar PPDB
            </a>
            <button id="mobile-menu-btn" class="lg:hidden p-2 text-primary focus:outline-none transition-colors" aria-label="Toggle Menu">
                <Menu id="menu-icon-svg" class="w-6 h-6 transition-transform" />
            </button>
        </div>
    </div>

    <div id="mobile-menu" class="fixed inset-0 bg-background/95 backdrop-blur-md z-40 transform translate-x-full transition-transform duration-300 lg:hidden flex flex-col justify-center items-center gap-8">
        <a href="/" class="mobile-link text-2xl font-heading text-primary">Beranda</a>
        <a href="/tentang" class="mobile-link text-2xl font-heading text-primary">Tentang Kami</a>
        <a href="/kurikulum" class="mobile-link text-2xl font-heading text-primary">Kurikulum</a>
        <a href="/kehidupan-asrama" class="mobile-link text-2xl font-heading text-primary">Kehidupan Asrama</a>
        <a href="/galeri" class="mobile-link text-2xl font-heading text-primary">Galeri</a>
        <a href="/kontak" class="mobile-link text-2xl font-heading text-primary">Hubungi Kami</a>
    </div>
</header>
