---
import { MapPin, Phone, Mail, ArrowRight } from '@lucide/astro';
---
<!-- Location & Contact -->
<section class="py-0 bg-white border-y border-border/30 flex flex-col md:flex-row h-auto md:h-[500px]">
    <!-- Map -->
    <div class="w-full md:w-1/2 h-[300px] md:h-full bg-gray-200">
        <!-- Google Maps officially updated to Mahad Pengembangan Dan Dakwah Nurul Haromain -->
        <iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3952.0229344440623!2d112.4530064!3d-7.8398681!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x2e787d67d2013307%3A0xc23afb6bba36fa55!2sMahad+Pengembangan+Dan+Dakwah+Nurul+Haromain!5e0!3m2!1sid!2sid!4v1700000000000!5m2!1sid!2sid" width="100%" height="100%" style="border:0;" allowfullscreen="" loading="lazy" referrerpolicy="no-referrer-when-downgrade"></iframe>
    </div>
    <!-- Contact Info -->
    <div class="w-full md:w-1/2 p-10 md:p-16 flex flex-col justify-center">
        <h2 class="font-heading text-3xl text-primary mb-6">Lokasi & Hubungi Kami</h2>
        <div class="space-y-8">
            <div class="flex items-start gap-4">
                <div class="w-10 h-10 rounded-full bg-background flex items-center justify-center text-gold shrink-0 border border-border/50">
                    <MapPin class="w-5 h-5" />
                </div>
                <div>
                    <h4 class="font-semibold text-primary">Alamat Resmi</h4>
                    <p class="text-sm text-muted">Jl. Brigjend Abd Manan Wijaya, Lebaksari, Ngroto,<br>Kecamatan Pujon, Kabupaten Malang, Jawa Timur 65391</p>
                    <a href="https://maps.app.goo.gl/THc1fmBWAQA9pHLUA" target="_blank" class="inline-flex items-center gap-1.5 text-xs font-semibold text-gold hover:text-primary transition-colors mt-2">
                        Buka Rute Google Maps <ArrowRight class="w-3.5 h-3.5" />
                    </a>
                </div>
            </div>
            <div class="flex items-start gap-4">
                <div class="w-10 h-10 rounded-full bg-background flex items-center justify-center text-gold shrink-0 border border-border/50">
                    <Phone class="w-5 h-5" />
                </div>
                <div>
                    <h4 class="font-semibold text-primary">Telepon / WhatsApp</h4>
                    <p class="text-sm text-muted">+62 812 3456 7890 (Layanan Informasi / PPDB)</p>
                </div>
            </div>
            <div class="flex items-start gap-4">
                <div class="w-10 h-10 rounded-full bg-background flex items-center justify-center text-gold shrink-0 border border-border/50">
                    <Mail class="w-5 h-5" />
                </div>
                <div>
                    <h4 class="font-semibold text-primary">Email Resmi</h4>
                    <p class="text-sm text-muted">info@nurulharomain-linnisa.sch.id</p>
                </div>
            </div>
        </div>
    </div>
</section>
