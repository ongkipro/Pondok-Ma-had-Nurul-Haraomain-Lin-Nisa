---
interface Props {
  className?: string;
}

const { className = "w-10 h-10" } = Astro.props;
---
<svg class={`${className} shadow-md transition-transform duration-300 hover:scale-105`} viewBox="0 0 100 100" fill="none" xmlns="http://www.w3.org/2000/svg">
    <!-- Outer concentric circle (gold) -->
    <circle cx="50" cy="50" r="48" stroke="#D4AF37" stroke-width="2.5" fill="#113a29" />
    <!-- Inner concentric circle (gold) -->
    <circle cx="50" cy="50" r="43" stroke="#D4AF37" stroke-width="1" stroke-dasharray="3 3" />
    
    <!-- Dome silhouette (gold outline, dark forest green fill) -->
    <path d="M50 18 C56 30, 68 34, 68 46 L32 46 C32 34, 44 30, 50 18 Z" fill="#092218" stroke="#D4AF37" stroke-width="1.8" />
    <!-- Dome top spire -->
    <line x1="50" y1="18" x2="50" y2="10" stroke="#D4AF37" stroke-width="1.8" />
    <!-- Crescent moon -->
    <path d="M49 9 A 3 3 0 1 1 52.5 12 A 2.5 2.5 0 1 0 49 9" fill="#D4AF37" />
    
    <!-- Open Book (Al-Quran) underneath the dome -->
    <!-- Left page -->
    <path d="M50 56 C44 52, 35 52, 27 55 L27 67 C35 64, 44 64, 50 68 Z" fill="#ffffff" stroke="#D4AF37" stroke-width="1.2" />
    <!-- Right page -->
    <path d="M50 56 C56 52, 65 52, 73 55 L73 67 C65 64, 56 64, 50 68 Z" fill="#ffffff" stroke="#D4AF37" stroke-width="1.2" />
    <!-- Book lines (details) -->
    <path d="M32 59 C37 57, 43 58, 47 60" stroke="#113a29" stroke-width="0.6" />
    <path d="M68 59 C63 57, 57 58, 53 60" stroke="#113a29" stroke-width="0.6" />
    <path d="M32 63 C37 61, 43 62, 47 64" stroke="#113a29" stroke-width="0.6" />
    <path d="M68 63 C63 61, 57 62, 53 64" stroke="#113a29" stroke-width="0.6" />
    
    <!-- Ribbons/Decorative base -->
    <path d="M20 76 Q50 83 80 76 L77 81 Q50 88 23 81 Z" fill="#D4AF37" />
    
    <!-- Stars (gold) -->
    <!-- Star 1 (left) -->
    <polygon points="26,24 27,27 30,27 28,29 29,32 26,30 23,32 24,29 22,27 25,27" fill="#D4AF37" />
    <!-- Star 2 (right) -->
    <polygon points="74,24 75,27 78,27 76,29 77,32 74,30 71,32 72,29 70,27 73,27" fill="#D4AF37" />
    <!-- Star 3 (top center) -->
    <polygon points="50,4 51,7 54,7 52,9 53,12 50,10 47,12 48,9 46,7 49,7" fill="#D4AF37" />
</svg>
