---
import Logo from './Logo.astro';
---
<footer class="bg-primary text-white pt-20 pb-10">
    <div class="max-w-7xl mx-auto px-6 md:px-12 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12 mb-16">
        
        <!-- Column 1: Brand -->
        <div>
            <a href="/" class="flex items-center gap-2.5 mb-6 shrink-0">
                <Logo className="w-10 h-10 shrink-0" />
                <div class="flex flex-col leading-none font-heading text-white">
                    <span class="text-[9px] md:text-[11px] font-semibold tracking-widest text-gold-on-dark uppercase mb-0.5">Ma'had Nurul Haromain</span>
                    <span class="text-sm md:text-base font-bold tracking-wide">Lin Nisa'</span>
                </div>
            </a>
            <p class="text-white/70 text-sm leading-relaxed mb-6">
                Mencetak generasi muslimah Rabbani yang shalihah, terampil, dan berjiwa da'iyah sesuai manhaj Ahlussunnah wal Jama'ah.
            </p>
            <!-- Social -->
            <div class="flex gap-4">
                <a href="https://www.instagram.com/mahadaly.nurulharomain/" target="_blank" rel="noopener noreferrer" class="w-8 h-8 rounded-full bg-white/10 flex items-center justify-center hover:bg-gold transition-colors text-white" aria-label="Kunjungi Instagram Kami">
                    <span class="sr-only">Instagram</span>
                    <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"></path></svg>
                </a>
            </div>
        </div>

        <!-- Column 2: Tautan -->
        <div>
            <h4 class="font-heading font-semibold text-lg text-gold-on-dark mb-6">Tautan Cepat</h4>
            <ul class="space-y-3">
                <li><a href="/tentang" class="text-white/70 hover:text-white text-sm transition-colors">Tentang Ma'had</a></li>
                <li><a href="/tentang#pengasuh" class="text-white/70 hover:text-white text-sm transition-colors">Pengasuh & Dewan Guru</a></li>
                <li><a href="/tentang#sanad" class="text-white/70 hover:text-white text-sm transition-colors">Sanad Keilmuan</a></li>
                <li><a href="/kehidupan-asrama" class="text-white/70 hover:text-white text-sm transition-colors">Fasilitas & Asrama</a></li>
                <li><a href="/#ppdb" class="text-white/70 hover:text-white text-sm transition-colors">Informasi PPDB</a></li>
            </ul>
        </div>

        <!-- Column 3: Program -->
        <div>
            <h4 class="font-heading font-semibold text-lg text-gold-on-dark mb-6">Program Pendidikan</h4>
            <ul class="space-y-3">
                <li><a href="/kurikulum" class="text-white/70 hover:text-white text-sm transition-colors">Madrasah Diniyyah Az-Zahra</a></li>
                <li><a href="/kurikulum" class="text-white/70 hover:text-white text-sm transition-colors">Madrasah Aliyah (MA)</a></li>
                <li><a href="/kurikulum" class="text-white/70 hover:text-white text-sm transition-colors">Tahfidz Al-Qur'an (Daar Tanzil)</a></li>
                <li><a href="/kurikulum" class="text-white/70 hover:text-white text-sm transition-colors">SMK Nurul Haromain (Putri)</a></li>
                <li><a href="/kurikulum" class="text-white/70 hover:text-white text-sm transition-colors">Kader Guru TK (KGTK)</a></li>
            </ul>
        </div>

        <!-- Column 4: Donasi / Info -->
        <div>
            <h4 class="font-heading font-semibold text-lg text-gold-on-dark mb-6">Dukungan & Infaq</h4>
            <p class="text-white/70 text-sm leading-relaxed mb-4">Dukung perjuangan pendidikan Islam dan pembinaan generasi Qur'ani.</p>
            <div class="bg-white/10 p-4 rounded-xl border border-white/20">
                <p class="text-xs text-white/60 mb-1">Bank Syariah Indonesia (BSI)</p>
                <p class="font-mono text-lg text-white mb-1 tracking-wider">1234 5678 90</p>
                <p class="text-xs text-[#D4B173]">a.n Yayasan Nurul Haromain Pujon</p>
            </div>
        </div>
    </div>

    <div class="border-t border-white/10">
        <div class="max-w-7xl mx-auto px-6 md:px-12 py-6 flex flex-col md:flex-row justify-between items-center gap-4 text-xs text-white/50">
            <p>&copy; {new Date().getFullYear()} Ma'had Nurul Haromain Lin Nisa'. Hak Cipta Dilindungi.</p>
            <div class="flex gap-4">
                <a href="#" class="hover:text-white transition-colors">Kebijakan Privasi</a>
                <a href="#" class="hover:text-white transition-colors">Syarat & Ketentuan</a>
            </div>
        </div>
    </div>
</footer>
