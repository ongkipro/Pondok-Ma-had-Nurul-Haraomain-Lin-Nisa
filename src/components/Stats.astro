<!-- Statistics Section -->
<section class="py-20 bg-primary text-white">
    <div class="max-w-7xl mx-auto px-6 md:px-12 grid grid-cols-2 md:grid-cols-4 gap-8 text-center divide-x divide-white/20">
        <div class="reveal p-4">
            <div class="font-heading text-5xl md:text-6xl text-gold mb-2 font-bold"><span class="counter" data-target="500">0</span>+</div>
            <div class="text-sm md:text-base text-white/80">Santriwati Aktif</div>
        </div>
        <div class="reveal reveal-delay-1 p-4">
            <div class="font-heading text-5xl md:text-6xl text-gold mb-2 font-bold"><span class="counter" data-target="50">0</span>+</div>
            <div class="text-sm md:text-base text-white/80">Asatidz & Murabbiyah</div>
        </div>
        <div class="reveal reveal-delay-2 p-4">
            <div class="font-heading text-5xl md:text-6xl text-gold mb-2 font-bold"><span class="counter" data-target="4">0</span></div>
            <div class="text-sm md:text-base text-white/80">Program Pilihan</div>
        </div>
        <div class="reveal reveal-delay-3 p-4">
            <div class="font-heading text-5xl md:text-6xl text-gold mb-2 font-bold"><span class="counter" data-target="35">0</span>+</div>
            <div class="text-sm md:text-base text-white/80">Tahun Pengalaman</div>
        </div>
    </div>
</section>
