---
import { Calendar, Check, ArrowRight, Download, MessageSquare } from '@lucide/astro';
---
<!-- Call to Action Banner -->
<section id="ppdb" class="py-12 md:py-24 px-4 sm:px-6 md:px-12 bg-background relative overflow-hidden">
    <!-- Decorative background elements -->
    <div class="absolute -top-40 -right-40 w-96 h-96 bg-primary/5 rounded-full filter blur-3xl pointer-events-none"></div>
    <div class="absolute -bottom-40 -left-40 w-96 h-96 bg-gold/5 rounded-full filter blur-3xl pointer-events-none"></div>

    <div class="max-w-6xl mx-auto rounded-[24px] md:rounded-[32px] overflow-hidden relative reveal shadow-premium border border-border/10 md:border-border/30 bg-primary">
        <!-- Background Image with deep tint overlay -->
        <img src="/images/cta-mosque.jpg" alt="Masjid Nurul Haromain" class="absolute inset-0 w-full h-full object-cover filter brightness-[0.35] contrast-105 pointer-events-none">
        
        <!-- Subtle dark green gradient blend -->
        <div class="absolute inset-0 bg-gradient-to-tr from-primary via-primary/95 to-transparent mix-blend-multiply pointer-events-none"></div>

        <div class="relative z-10 py-10 px-6 sm:py-16 sm:px-10 md:py-20 md:px-16 grid lg:grid-cols-12 gap-8 lg:gap-16 items-center">
            
            <!-- Left Column: Copy & Actions -->
            <div class="lg:col-span-7 text-left text-white">
                <span class="inline-flex items-center gap-2 py-1.5 px-4 rounded-full bg-gold/20 text-gold border border-gold/40 font-semibold text-xs tracking-wider uppercase mb-5 backdrop-blur-sm">
                    <Calendar class="w-3.5 h-3.5" /> Penerimaan Santriwati Baru (PPDB) 2026/2027
                </span>
                
                <h2 class="font-heading text-3xl md:text-5xl lg:text-6xl mb-4 md:mb-6 leading-tight">
                    Jadilah Bagian dari <br class="hidden sm:inline"><span class="text-gold">Generasi Qur'ani</span>
                </h2>
                
                <p class="text-white/80 max-w-xl mb-8 md:mb-10 text-xs md:text-base leading-relaxed">
                    Kuota pendaftaran dibatasi secara selektif untuk menjaga rasio guru dan santri demi maksimalnya transfer adab, hafalan Al-Qur'an mutqin, serta pemahaman kitab turats.
                </p>
                
                <div class="flex flex-col sm:flex-row gap-3 w-full">
                    <a href="https://wa.me/6281234567890" target="_blank" class="w-full sm:w-auto inline-flex items-center justify-center gap-2.5 px-6 py-3.5 rounded-full bg-gold text-primary text-sm font-bold hover:bg-white hover:text-primary transition-all duration-300 shadow-lg transform hover:-translate-y-0.5 active:translate-y-0 text-center">
                        <MessageSquare class="w-4 h-4 fill-current" /> Hubungi Panitia (WhatsApp)
                    </a>
                    <a href="#" class="w-full sm:w-auto inline-flex items-center justify-center gap-2 px-6 py-3.5 rounded-full bg-white/10 backdrop-blur-sm border border-white/20 text-white text-sm font-medium hover:bg-white/20 transition-all duration-300 text-center">
                        <Download class="w-4 h-4" /> Download Brosur (PDF)
                    </a>
                </div>
            </div>

            <!-- Right Column: Glassmorphic admission details (Desktop gets Card wrapper, Mobile gets clean flat content) -->
            <div class="lg:col-span-5 w-full border-t border-white/10 lg:border-t-0 pt-8 lg:pt-0 mt-4 lg:mt-0">
                <div class="bg-transparent lg:bg-white/10 lg:backdrop-blur-md lg:border lg:border-white/20 lg:rounded-3xl p-0 lg:p-8 text-white lg:shadow-xl relative overflow-hidden">
                    <!-- Subtle ambient lighting (Desktop only) -->
                    <div class="absolute -top-20 -left-20 w-40 h-40 bg-gold/10 rounded-full filter blur-2xl hidden lg:block"></div>

                    <h3 class="font-heading text-lg md:text-xl font-bold text-white mb-6 flex items-center gap-2 border-b border-white/15 pb-4">
                        Informasi Gelombang
                    </h3>

                    <!-- Gelombang Items -->
                    <div class="space-y-4 mb-6">
                        <div class="flex justify-between items-center bg-white/5 hover:bg-white/10 transition-colors p-3.5 rounded-xl border border-white/5">
                            <div>
                                <h4 class="font-semibold text-xs md:text-sm">Gelombang I (Reguler)</h4>
                                <p class="text-[10px] md:text-[11px] text-white/60">Pendaftaran & Seleksi Berkas</p>
                            </div>
                            <span class="text-[10px] md:text-[11px] font-bold text-emerald-400 bg-emerald-400/10 px-2.5 py-1 rounded-full uppercase border border-emerald-400/20">Aktif</span>
                        </div>
                        
                        <div class="flex justify-between items-center bg-white/5 p-3.5 rounded-xl border border-white/5 opacity-60">
                            <div>
                                <h4 class="font-semibold text-xs md:text-sm">Gelombang II</h4>
                                <p class="text-[10px] md:text-[11px] text-white/60">Akan dibuka jika kuota tersedia</p>
                            </div>
                            <span class="text-[10px] md:text-[11px] font-bold text-white/50 bg-white/5 px-2.5 py-1 rounded-full uppercase">Tutup</span>
                        </div>
                    </div>

                    <!-- Admission Requirements Check -->
                    <h4 class="font-semibold text-xs text-gold uppercase tracking-wider mb-3">Persyaratan Utama</h4>
                    <ul class="space-y-2.5 text-xs text-white/95">
                        <li class="flex items-start gap-2.5">
                            <span class="w-4 h-4 rounded-full bg-gold/20 text-gold flex items-center justify-center shrink-0 mt-0.5"><Check class="w-3 h-3" /></span>
                            <span>Lulus SD/MI (untuk Aliyah/SMK/Diniyah)</span>
                        </li>
                        <li class="flex items-start gap-2.5">
                            <span class="w-4 h-4 rounded-full bg-gold/20 text-gold flex items-center justify-center shrink-0 mt-0.5"><Check class="w-3 h-3" /></span>
                            <span>Mampu membaca Al-Qur'an secara lancar</span>
                        </li>
                        <li class="flex items-start gap-2.5">
                            <span class="w-4 h-4 rounded-full bg-gold/20 text-gold flex items-center justify-center shrink-0 mt-0.5"><Check class="w-3 h-3" /></span>
                            <span>Berakhlak baik & siap mematuhi disiplin pondok</span>
                        </li>
                    </ul>
                </div>
            </div>

        </div>
    </div>
</section>
