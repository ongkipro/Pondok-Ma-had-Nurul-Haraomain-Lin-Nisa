---
import { Book, GraduationCap, Award, Laptop, Heart } from '@lucide/astro';

const programs = [
  {
    title: "Madrasah Diniyyah Az-Zahra",
    description: "Mengkaji kitab kuning (turats) dengan metode salaf, difokuskan pada tafsir, hadits, dan fiqih wanita.",
    icon: Book,
    tag: "Kitab Turats"
  },
  {
    title: "Madrasah Aliyah (MA)",
    description: "Pendidikan formal tingkat menengah atas yang terakreditasi nasional, mensinergikan sains dan iman.",
    icon: GraduationCap,
    tag: "Formal Kemendag"
  },
  {
    title: "Tahfidz Daar Tanzil / Ribath Al-Hadi",
    description: "Hafalan Al-Qur'an 30 juz secara intensif dengan metode mutqin, bersanad, dan bimbingan akhlak.",
    icon: Award,
    tag: "Hafalan & Sanad"
  },
  {
    title: "SMK Nurul Haromain (Putri)",
    description: "Pendidikan kejuruan putri dengan spesialisasi Teknik Jaringan Komputer & Telekomunikasi (TJKT) serta Desain Busana.",
    icon: Laptop,
    tag: "Kejuruan & Skill"
  },
  {
    title: "Program KGTK",
    description: "Program khusus kader pendidik anak usia dini yang berbekal akhlak Islami dan keilmuan agama yang kokoh.",
    icon: Heart,
    tag: "Kader Pendidik"
  }
];
---
<!-- Programs Section -->
<section id="program" class="py-12 md:py-16 lg:py-24 bg-background">
    <div class="max-w-7xl mx-auto px-6 md:px-12">
        <div class="text-left md:text-center max-w-2xl mx-auto mb-10 md:mb-16 reveal">
            <span class="text-gold font-semibold text-xs md:text-sm tracking-widest uppercase mb-3 block">Kurikulum Terintegrasi</span>
            <h2 class="font-heading text-3xl md:text-5xl text-primary mb-4 md:mb-6">Program Pendidikan Putri</h2>
            <p class="text-muted text-sm md:text-base">Menyediakan jenjang pendidikan terpadu, memadukan pendalaman ilmu salaf, target hafalan Al-Qur'an, dan pendidikan umum.</p>
        </div>

        <!-- Mobile view: Sleek Cards with Shadows and Accents -->
        <div class="block md:hidden space-y-5 reveal">
            {programs.map((p) => {
                const IconComponent = p.icon;
                return (
                    <div class="bg-white rounded-2xl p-5 border border-border/40 shadow-[0_4px_20px_rgba(18,53,36,0.03)] flex gap-4 active:scale-[0.98] transition-all duration-300">
                        <div class="w-10 h-10 rounded-xl bg-gradient-to-tr from-primary to-primary/80 text-white flex items-center justify-center shrink-0 shadow-md">
                            <IconComponent class="w-5 h-5" />
                        </div>
                        <div class="flex-grow">
                            <div class="flex items-center justify-between gap-2 mb-1.5">
                                <h3 class="font-heading text-base font-bold text-primary leading-tight">{p.title}</h3>
                                <span class="text-[9px] font-bold text-gold bg-gold/10 px-2.5 py-0.5 rounded-full uppercase border border-gold/20 whitespace-nowrap shrink-0">{p.tag}</span>
                            </div>
                            <p class="text-xs text-muted leading-relaxed">{p.description}</p>
                        </div>
                    </div>
                );
            })}
        </div>

        <!-- Desktop view: Premium Card Grid -->
        <div class="hidden md:flex md:flex-wrap md:justify-center gap-8 max-w-6xl mx-auto reveal">
            {programs.map((p) => {
                const IconComponent = p.icon;
                return (
                    <div class="bg-card rounded-2xl shadow-premium border border-border/40 overflow-hidden hover:shadow-premium-hover hover:border-gold/30 transition-all duration-300 transform hover:-translate-y-2 group min-w-[280px] w-[calc(50%-16px)] lg:w-[calc(33.333%-22px)] flex flex-col justify-between shrink-0 relative">
                        <!-- Decorative top accent bar -->
                        <div class="absolute top-0 left-0 right-0 h-1 bg-gradient-to-r from-primary via-gold to-primary opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
                        <div class="p-6 flex flex-col h-full">
                            <!-- Icon and Tag Header -->
                            <div class="flex items-center justify-between gap-4 mb-6">
                                <div class="w-12 h-12 bg-background shadow-md rounded-full flex items-center justify-center text-gold border border-border/30 shrink-0">
                                    <IconComponent class="w-6 h-6" />
                                </div>
                                <span class="text-xs font-bold text-gold bg-gold/10 px-2.5 py-1 rounded-full uppercase border border-gold/10 whitespace-nowrap shrink-0">{p.tag}</span>
                            </div>
                            <h3 class="font-heading text-xl font-bold text-primary mb-3 leading-tight">{p.title}</h3>
                            <p class="text-muted text-sm leading-relaxed">{p.description}</p>
                        </div>
                    </div>
                );
            })}
        </div>
    </div>
</section>
