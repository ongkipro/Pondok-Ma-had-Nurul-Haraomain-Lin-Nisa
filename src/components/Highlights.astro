---
import { BookOpen, ShieldCheck, Globe, HeartHandshake, School, Layers } from '@lucide/astro';

const highlights = [
  {
    title: "Sanad Keilmuan Murni",
    description: "Mata rantai keilmuan bersambung langsung ke tanah suci Makkah melalui bimbingan keluarga Al-Maliki.",
    icon: BookOpen
  },
  {
    title: "Keamanan Asrama Terjamin",
    description: "Lingkungan asrama putri tertutup dengan sistem keamanan dan pengawasan asatidz/murabbiyah 24 jam.",
    icon: ShieldCheck
  },
  {
    title: "Fokus Hadits & Bahasa",
    description: "Spesialisasi kajian hadits primer (Kutubus Sittah) serta pembiasaan percakapan harian Bahasa Arab dan Inggris.",
    icon: Globe
  },
  {
    title: "Pembinaan Akhlak Mulia",
    description: "Menitikberatkan keteladanan harian dan pengasuhan hati secara personal dari pembimbing.",
    icon: HeartHandshake
  },
  {
    title: "Lingkungan Asri & Sejuk",
    description: "Terletak di pegunungan Pujon yang tenang, jauh dari hiruk-pikuk kota, ideal untuk konsentrasi belajar.",
    icon: School
  },
  {
    title: "Pendidikan Terintegrasi",
    description: "Menggabungkan ijazah formal negara, hafalan Al-Qur'an, dan penguasaan kitab salaf dalam satu waktu.",
    icon: Layers
  },
  {
    title: "Fasilitas Belajar Standar Industri",
    description: "Dilengkapi laboratorium komputer spesifikasi tinggi, laboratorium bahasa, serta bengkel busana bagi program SMK.",
    icon: School
  },
  {
    title: "Klinik Khusus Putri",
    description: "Layanan kesehatan khusus terpisah untuk santriwati guna menjamin kenyamanan, privasi, dan kesiagaan medis.",
    icon: ShieldCheck
  }
];
---
<!-- Why Choose Us -->
<section class="py-12 md:py-16 lg:py-24 bg-background border-y border-border/10 md:border-border/30">
    <div class="max-w-7xl mx-auto px-6 md:px-12 grid lg:grid-cols-3 gap-8 lg:gap-12 items-start">
        <div class="lg:col-span-1 lg:sticky lg:top-32 reveal">
            <span class="text-gold font-semibold text-xs md:text-sm tracking-widest uppercase mb-3 block">Nilai Lebih</span>
            <h2 class="font-heading text-3xl md:text-4xl text-primary mb-4 md:mb-6">Mengapa Memilih Lin Nisa'?</h2>
            <p class="text-muted text-sm md:text-base mb-6 md:mb-8">Pendidikan terarah dengan bimbingan intensif dan kuota selektif demi menjaga kualitas tumbuh kembang setiap santriwati.</p>
            <a href="#ppdb" class="inline-flex items-center justify-center px-8 py-3.5 rounded-full bg-primary text-white text-sm font-semibold hover:bg-primary/90 transition-all shadow-md">
                Daftar Sekarang
            </a>
        </div>

        <div class="lg:col-span-2 grid sm:grid-cols-2 gap-6 md:gap-8">
            {highlights.map((h) => {
                const IconComponent = h.icon;
                return (
                    <div class="reveal bg-card p-5 rounded-2xl border border-border/40 hover:border-gold/30 hover:shadow-premium-hover transition-all duration-300 flex gap-4 items-start group transform hover:-translate-y-1 active:scale-[0.98] md:active:scale-100">
                        <div class="w-10 h-10 rounded-xl bg-primary/10 text-primary flex items-center justify-center shrink-0 group-hover:bg-primary group-hover:text-white transition-all duration-300 shadow-sm">
                            <IconComponent class="w-5 h-5" />
                        </div>
                        <div>
                            <h3 class="font-heading text-base font-bold text-primary mb-1.5 leading-tight">{h.title}</h3>
                            <p class="text-xs text-muted leading-relaxed">{h.description}</p>
                        </div>
                    </div>
                );
            })}
        </div>
    </div>
</section>
