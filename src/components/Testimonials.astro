---
const testimonials = [
  {
    name: "Bapak Arief",
    program: "Wali Santri Program Tahfidz",
    text: "Alhamdulillah, sejak mondok di sini, perubahan adab putri kami sangat terlihat. Hafalannya lancar berkat bimbingan intensif yang disiplin namun penuh rasa kasih sayang.",
    rating: 5,
    image: "/images/testimonials/parent-arief.jpg"
  },
  {
    name: "Ibu Fatimah",
    program: "Wali Santri Madrasah Aliyah",
    text: "Lingkungan asrama di Pujon sangat sejuk dan aman. Saya merasa sangat tenang menitipkan putri kami di asrama yang bersih dan terjaga secara islami.",
    rating: 5,
    image: "/images/testimonials/parent-fatimah.jpg"
  },
  {
    name: "Bapak Susanto",
    program: "Wali Santri Madrasah Diniyyah",
    text: "Perpaduan pelajaran kitab salaf dan keahlian keputrian seperti agribisnis minimalis (TETRIS) sangat mendidik kemandirian anak kami untuk masa depannya.",
    rating: 5,
    image: "/images/testimonials/parent-susanto.jpg"
  },
  {
    name: "Ibu Aminah",
    program: "Wali Santri SMK Nurul Haromain",
    text: "Program kejuruan TJKT dan Tata Busana di SMK benar-benar berstandar industri. Selain mahir merancang busana, putri saya juga tetap lancar mengaji kitab kuning.",
    rating: 5,
    image: "/images/testimonials/parent-aminah.jpg"
  },
  {
    name: "Bapak H. Rahmad",
    program: "Wali Santri Asal Surabaya",
    text: "Sistem pengajaran sanad keilmuan yang bersambung langsung ke keluarga Al-Maliki Makkah membuat kami yakin bahwa ilmu agama yang diajarkan di sini orisinal dan bersih.",
    rating: 5,
    image: "/images/testimonials/parent-rahmad.jpg"
  },
  {
    name: "Ibu dr. Sarah",
    program: "Wali Santri Program KGTK",
    text: "Sebagai dokter, saya sangat mengapresiasi kebersihan asrama dan keberadaan Klinik Khusus Putri mandiri di dalam pondok. Fasilitas kesehatan ini sangat menjaga privasi santriwati.",
    rating: 5,
    image: "/images/testimonials/parent-sarah.jpg"
  }
];

const getInitials = (name: string) => {
  return name.split(' ').map(n => n[0]).join('').slice(0, 2);
};

const getGradient = (index: number) => {
  const gradients = [
    "from-primary to-secondary",
    "from-gold to-primary/80",
    "from-[#2A52BE] to-primary/70",
    "from-secondary to-gold",
    "from-[#113a29] to-primary",
    "from-gold/90 to-secondary"
  ];
  return gradients[index % gradients.length];
};
---
<!-- Testimonials Section -->
<section class="py-12 md:py-16 lg:py-24 bg-white">
    <div class="max-w-7xl mx-auto px-6 md:px-12">
        <div class="text-left md:text-center mb-10 md:mb-16 reveal">
            <span class="text-gold font-semibold text-xs md:text-sm tracking-widest uppercase mb-3 block">Bukti Nyata</span>
            <h2 class="font-heading text-3xl md:text-5xl text-primary mb-4 md:mb-6">Apa Kata Wali Santri?</h2>
            <p class="text-muted text-sm md:text-base max-w-2xl mx-auto">Pengalaman dan kesaksian tulus dari orang tua/wali santriwati seputar perkembangan pendidikan, karakter, dan fasilitas asrama putri.</p>
        </div>
        
        <!-- Mobile view: Flat circular profile list rows (No cards, no scroll, no borders) -->
        <div class="block md:hidden space-y-6 reveal">
            {testimonials.map((t, idx) => (
                <div class="flex gap-4 border-b border-border/10 pb-5 last:border-b-0 last:pb-0">
                    <!-- Profile Photo or Initial Fallback -->
                    {t.image ? (
                        <div class="w-12 h-12 rounded-full overflow-hidden shrink-0 border border-border bg-background shadow-sm">
                            <img src={t.image} alt={t.name} class="w-full h-full object-cover" />
                        </div>
                    ) : (
                        <div class={`w-12 h-12 rounded-full shrink-0 bg-gradient-to-tr ${getGradient(idx)} flex items-center justify-center text-white font-bold text-sm shadow-sm`}>
                            {getInitials(t.name)}
                        </div>
                    )}
                    <div class="flex-grow">
                        <div class="flex items-center justify-between gap-2 mb-1">
                            <h4 class="font-semibold text-primary text-sm">{t.name}</h4>
                            <div class="flex text-gold text-xs">
                                {Array.from({ length: t.rating }).map(() => <span>★</span>)}
                            </div>
                        </div>
                        <p class="text-xs text-muted/80 mb-2">{t.program}</p>
                        <p class="text-xs text-muted italic leading-relaxed">"{t.text}"</p>
                    </div>
                </div>
            ))}
        </div>
        
        <!-- Desktop/Tablet view: Multi-Column Responsive Grid -->
        <div class="hidden md:grid md:grid-cols-2 lg:grid-cols-3 gap-8 max-w-6xl mx-auto reveal">
            {testimonials.map((t, idx) => (
                <div class="bg-background p-8 rounded-2xl shadow-sm border border-border/50 hover:shadow-premium-hover transition-all duration-300 transform hover:-translate-y-1 flex flex-col justify-between">
                    <div>
                        <!-- Rating Stars -->
                        <div class="flex text-gold mb-4 gap-0.5">
                            {Array.from({ length: t.rating }).map(() => <span class="text-lg">★</span>)}
                        </div>
                        <!-- Review Text -->
                        <p class="text-muted italic text-sm leading-relaxed mb-6">"{t.text}"</p>
                    </div>
                    
                    <!-- Bio & Profile Row -->
                    <div class="flex items-center gap-4 border-t border-border/30 pt-4 mt-auto">
                        <!-- Profile Photo or Initial Fallback -->
                        {t.image ? (
                            <div class="w-10 h-10 rounded-full overflow-hidden shrink-0 border border-border bg-white shadow-sm">
                                <img src={t.image} alt={t.name} class="w-full h-full object-cover" />
                            </div>
                        ) : (
                            <div class={`w-10 h-10 rounded-full shrink-0 bg-gradient-to-tr ${getGradient(idx)} flex items-center justify-center text-white font-bold text-xs shadow-sm`}>
                                {getInitials(t.name)}
                            </div>
                        )}
                        <div>
                            <h4 class="font-heading font-bold text-primary text-sm leading-tight">{t.name}</h4>
                            <p class="text-[11px] text-muted leading-tight mt-0.5">{t.program}</p>
                        </div>
                    </div>
                </div>
            ))}
        </div>
    </div>
</section>
