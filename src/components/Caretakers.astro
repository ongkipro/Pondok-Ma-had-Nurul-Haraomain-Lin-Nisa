---
---
<!-- Caretakers Profiles (New Featured Layout) -->
<!-- Caretakers Profiles (New Featured Layout) -->
<section id="pengasuh" class="py-12 md:py-16 lg:py-24 bg-background">
    <div class="max-w-7xl mx-auto px-6 md:px-12">
        <div class="text-left md:text-center max-w-2xl mx-auto mb-12 md:mb-20 reveal">
            <span class="text-gold font-semibold text-xs md:text-sm tracking-widest uppercase mb-3 block">Masyayikh & Pembimbing</span>
            <h2 class="font-heading text-3xl md:text-5xl text-primary mb-4 md:mb-6">Pengasuh & Dewan Guru</h2>
            <p class="text-muted text-sm md:text-base">Dibimbing langsung di bawah restu para ulama terkemuka dari Makkah Al-Mukarramah dan diasuh oleh asatidz berpengalaman.</p>
        </div>

        <!-- Mobile view: Flat circular profile list rows (No cards, no borders, no shadows) -->
        <div class="block md:hidden space-y-8 reveal mb-12">
            <!-- Abina KH. Ihya Ulumiddin -->
            <div class="bg-card rounded-2xl p-6 border border-border/50 shadow-sm flex flex-col items-center text-center">
                <!-- Circular Avatar (centered, larger) -->
                <div class="w-24 h-24 rounded-full overflow-hidden border-2 border-gold/40 shadow-md bg-white mb-4 shrink-0">
                    <img src="/images/kh-muhammad-ihya-ulumiddin.webp" alt="Foto Abina KH. Muhammad Ihya' Ulumiddin - Pengasuh Utama" class="w-full h-full object-cover filter brightness-95" width="96" height="96" loading="lazy" decoding="async" />
                </div>
                <div>
                    <span class="text-[9px] font-bold text-gold bg-gold/10 px-2.5 py-1 rounded-full uppercase border border-gold/20 inline-block mb-3">Pengasuh Utama & Nazhir</span>
                    <h3 class="font-heading text-xl font-bold text-primary mb-2">Abina KH. Muhammad Ihya' Ulumiddin</h3>
                    <p class="text-xs text-muted leading-relaxed mb-4">Alumni Abuya Sayyid Muhammad bin Alawy Al-Maliki Makkah. Mendedikasikan hidup untuk penyebaran hadits, fikih aswaja, dan pembinaan akhlak santriwati.</p>
                    
                    <!-- Quote Box -->
                    <div class="border-t border-border/20 pt-3 mt-3">
                        <p class="text-xs text-primary font-semibold italic">"Membentuk muslimah shalihah adalah pilar utama peradaban Islam."</p>
                    </div>
                </div>
            </div>

            <!-- Masyayikh Tahtal Isyrof Header -->
            <h4 class="font-heading text-lg text-primary font-bold pt-4 mb-4">Pembimbing Spiritual & Keilmuan</h4>
            
            <div class="space-y-6">
                <!-- Abuya Sayyid Muhammad Al-Maliki -->
                <div class="flex gap-4 items-center">
                    <div class="w-14 h-14 rounded-full overflow-hidden border border-border/30 shrink-0 shadow-sm bg-white">
                        <img src="/images/abuya-sayyid-muhammad-al-maliki.webp" alt="Foto Abuya Prof. Dr. Sayyid Muhammad bin Alawy Al-Maliki" class="w-full h-full object-cover" width="56" height="56" loading="lazy" decoding="async" />
                    </div>
                    <div>
                        <span class="text-[9px] font-semibold text-gold tracking-wide uppercase block">Pembimbing Ruhani (Makkah)</span>
                        <h5 class="font-heading text-base font-bold text-primary">Abuya Prof. Dr. Sayyid Muhammad Al-Maliki</h5>
                        <p class="text-xs text-muted leading-relaxed mt-0.5">Ulama kharismatik asal Makkah Al-Mukarramah, Muhaddis abad ini.</p>
                    </div>
                </div>

                <!-- Abuya Sayyid Ahmad Al-Maliki -->
                <div class="flex gap-4 items-center">
                    <div class="w-14 h-14 rounded-full overflow-hidden border border-border/30 shrink-0 shadow-sm bg-white">
                        <img src="/images/abuya-sayyid-ahmad-al-maliki.webp" alt="Foto Abuya Sayyid Ahmad bin Muhammad Al-Maliki" class="w-full h-full object-cover" width="56" height="56" loading="lazy" decoding="async" />
                    </div>
                    <div>
                        <span class="text-[9px] font-semibold text-gold tracking-wide uppercase block">Penerus Bimbingan (Makkah)</span>
                        <h5 class="font-heading text-base font-bold text-primary">Abuya Sayyid Ahmad bin Muhammad Al-Maliki</h5>
                        <p class="text-xs text-muted leading-relaxed mt-0.5">Penerus estafet keilmuan dan thariqah Al-Maliki di Makkah.</p>
                    </div>
                </div>

                <!-- KH. Syihabuddin Syifa' -->
                <div class="flex gap-4 items-center">
                    <div class="w-14 h-14 rounded-full overflow-hidden border border-border/30 shrink-0 shadow-sm bg-white">
                        <img src="/images/kh-syihabuddin-syifa.webp" alt="Foto KH. Syihabuddin Syifa'" class="w-full h-full object-cover" width="56" height="56" loading="lazy" decoding="async" />
                    </div>
                    <div>
                        <span class="text-[9px] font-semibold text-gold tracking-wide uppercase block">Dewan Pembimbing</span>
                        <h5 class="font-heading text-base font-bold text-primary">KH. Syihabuddin Syifa'</h5>
                        <p class="text-xs text-muted leading-relaxed mt-0.5">Ulama pembimbing spiritual dan keilmuan lokal.</p>
                    </div>
                </div>
            </div>
        </div>

        <!-- Desktop view: Premium Featured Card & Advisor Grid -->
        <div class="hidden md:block">
            <!-- 1. Pengasuh Utama (Abina KH. Muhammad Ihya' Ulumiddin) - Featured Layout -->
            <div class="mb-20 reveal">
                <div class="bg-card rounded-3xl overflow-hidden border border-border/50 shadow-premium p-8 lg:p-12 max-w-5xl mx-auto grid md:grid-cols-5 gap-8 lg:gap-12 items-center">
                    <!-- Photo Container -->
                    <div class="md:col-span-2 aspect-square rounded-2xl overflow-hidden bg-background border border-border/30 shadow-inner">
                        <img src="/images/kh-muhammad-ihya-ulumiddin.webp" alt="Foto Portrait Abina KH. Muhammad Ihya' Ulumiddin" class="w-full h-full object-cover filter brightness-95 hover:scale-105 transition-transform duration-500" width="400" height="400" loading="lazy" decoding="async" />
                    </div>
                    <!-- Bio & Message -->
                    <div class="md:col-span-3">
                        <span class="inline-block py-1 px-3 rounded-full bg-gold/10 text-gold font-semibold text-xs tracking-wider uppercase mb-4 border border-gold/20">
                            Pengasuh Utama & Nazhir
                        </span>
                        <h3 class="font-heading text-3xl font-bold text-primary mb-4 leading-tight">Abina KH. Muhammad Ihya' Ulumiddin</h3>
                        <p class="text-muted text-sm leading-relaxed mb-6">
                            Beliau merupakan murid langsung (alumni) dari Abuya Sayyid Muhammad bin Alawy Al-Maliki di Makkah Al-Mukarramah yang belajar selama bertahun-tahun di tanah suci. Sebagai pendiri dan pengasuh utama jaringan Ma'had Nurul Haromain, beliau mendedikasikan hidupnya untuk menyebarkan ilmu hadits, fikih Ahlussunnah wal Jama'ah, dan mendidik santriwati menjadi pilar dakwah di masyarakat.
                        </p>
                        <!-- Quote Box -->
                        <div class="border-l-4 border-gold pl-4 py-2 bg-background/50 rounded-r-xl">
                            <p class="text-xs text-primary font-medium italic">"Membentuk muslimah shalihah adalah pilar utama terwujudnya peradaban Islam yang kokoh."</p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- 2. Pembimbing Utama (Tahtal Isyrof) - Grid 3 Columns -->
            <div>
                <h4 class="font-heading text-2xl text-center text-primary mb-12 font-bold reveal">Pembimbing Spiritual & Keilmuan (Tahtal Isyrof)</h4>
                
                <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8 max-w-6xl mx-auto">
                    <!-- Abuya Sayyid Muhammad Al-Maliki -->
                    <div class="bg-card rounded-2xl overflow-hidden border border-border/50 shadow-premium hover:shadow-premium-hover transition-all duration-300 transform hover:-translate-y-2 flex flex-col justify-between reveal">
                        <div class="p-4 flex-grow">
                            <div class="aspect-square rounded-xl overflow-hidden mb-6 bg-background border border-border/30">
                                <img src="/images/abuya-sayyid-muhammad-al-maliki.webp" alt="Foto Abuya Prof. Dr. Sayyid Muhammad bin Alawy Al-Maliki Al-Hasani" class="w-full h-full object-cover filter brightness-95 hover:scale-105 transition-transform duration-500" width="300" height="300" loading="lazy" decoding="async" />
                            </div>
                            <div class="px-2">
                                <span class="text-xs font-semibold text-gold tracking-wide uppercase block mb-1">Pembimbing Ruhani (Makkah)</span>
                                <h5 class="font-heading text-lg font-bold text-primary mb-2 leading-tight">Abuya Prof. Dr. Sayyid Muhammad bin Alawy Al-Maliki</h5>
                                <p class="text-xs text-muted leading-relaxed">Ulama kharismatik asal Makkah Al-Mukarramah, Muhaddis abad ini, dan guru utama pengasuh pesantren.</p>
                            </div>
                        </div>
                        <div class="px-6 py-3 bg-background/50 border-t border-border/30 text-center">
                            <span class="text-xs text-primary font-medium">Sanad Keilmuan Utama</span>
                        </div>
                    </div>

                    <!-- Abuya Sayyid Ahmad Al-Maliki -->
                    <div class="bg-card rounded-2xl overflow-hidden border border-border/50 shadow-premium hover:shadow-premium-hover transition-all duration-300 transform hover:-translate-y-2 flex flex-col justify-between reveal">
                        <div class="p-4 flex-grow">
                            <div class="aspect-square rounded-xl overflow-hidden mb-6 bg-background border border-border/30">
                                <img src="/images/abuya-sayyid-ahmad-al-maliki.webp" alt="Foto Abuya Sayyid Ahmad bin Muhammad Al-Maliki Al-Hasani" class="w-full h-full object-cover filter brightness-95 hover:scale-105 transition-transform duration-500" width="300" height="300" loading="lazy" decoding="async" />
                            </div>
                            <div class="px-2">
                                <span class="text-xs font-semibold text-gold tracking-wide uppercase block mb-1">Penerus Bimbingan (Makkah)</span>
                                <h5 class="font-heading text-lg font-bold text-primary mb-2 leading-tight">Abuya Sayyid Ahmad bin Muhammad Al-Maliki</h5>
                                <p class="text-xs text-muted leading-relaxed">Penerus estafet bimbingan keilmuan dan thariqah keluarga Al-Maliki di Makkah Al-Mukarramah.</p>
                            </div>
                        </div>
                        <div class="px-6 py-3 bg-background/50 border-t border-border/30 text-center">
                            <span class="text-xs text-primary font-medium">Estafet Sanad & Berkah</span>
                        </div>
                    </div>

                    <!-- KH. Syihabuddin Syifa' -->
                    <div class="bg-card rounded-2xl overflow-hidden border border-border/50 shadow-premium hover:shadow-premium-hover transition-all duration-300 transform hover:-translate-y-2 flex flex-col justify-between reveal">
                        <div class="p-4 flex-grow">
                            <div class="aspect-square rounded-xl overflow-hidden mb-6 bg-background border border-border/30">
                                <img src="/images/kh-syihabuddin-syifa.webp" alt="Foto KH. Syihabuddin Syifa'" class="w-full h-full object-cover filter brightness-95 hover:scale-105 transition-transform duration-500" width="300" height="300" loading="lazy" decoding="async" />
                            </div>
                            <div class="px-2">
                                <span class="text-xs font-semibold text-gold tracking-wide uppercase block mb-1">Dewan Pembimbing</span>
                                <h5 class="font-heading text-lg font-bold text-primary mb-2 leading-tight">KH. Syihabuddin Syifa'</h5>
                                <p class="text-xs text-muted leading-relaxed">Ulama pembimbing spiritual dan keilmuan yang turut mengarahkan program dakwah serta thariqah santriwati.</p>
                            </div>
                        </div>
                        <div class="px-6 py-3 bg-background/50 border-t border-border/30 text-center">
                            <span class="text-xs text-primary font-medium">Bimbingan Spiritual Lokal</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
