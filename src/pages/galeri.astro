---
import Layout from '../layouts/Layout.astro';
import PPDB from '../components/PPDB.astro';
import { ZoomIn, X, ChevronLeft, ChevronRight, MapPin } from '@lucide/astro';

const categories = [
  { id: "all", name: "Semua Foto" },
  { id: "fasilitas", name: "Fasilitas Ma'had" },
  { id: "lingkungan", name: "Lingkungan & Alam" },
  { id: "kemandirian", name: "Kemandirian Pangan" }
];

const categoryLabel: Record<string, string> = {
  fasilitas: "Fasilitas",
  lingkungan: "Lingkungan",
  kemandirian: "Kemandirian"
};

// Foto otentik lokasi Ma'had Nurul Haromain, Ngroto - Pujon, Malang.
const galleryItems = [
  {
    src: "/images/gmaps/gedung-utama.webp",
    title: "Kompleks Gedung Ma'had",
    category: "fasilitas",
    description: "Bangunan asrama bertingkat dengan menara khas Ma'had Nurul Haromain di kaki pegunungan Ngroto, Pujon."
  },
  {
    src: "/images/gmaps/papan-nama.webp",
    title: "Gerbang Ma'had Nurul Haromain",
    category: "fasilitas",
    description: "Papan nama dan pintu masuk utama Ma'had Nurul Haromain di Ngroto, Pujon, Kabupaten Malang."
  },
  {
    src: "/images/gmaps/lingkungan-pegunungan.webp",
    title: "Panorama Pegunungan Pujon",
    category: "lingkungan",
    description: "Hamparan sawah dan barisan pegunungan Pujon yang sejuk menjadi lingkungan belajar santriwati."
  },
  {
    src: "/images/gmaps/kebun-sayur.webp",
    title: "Kebun Sayur Organik",
    category: "kemandirian",
    description: "Lahan budi daya sayur organik di sekitar Ma'had sebagai program kemandirian pangan dan keterampilan santriwati."
  },
  {
    src: "/images/gmaps/gedung-taman.webp",
    title: "Taman & Menara Pandang",
    category: "fasilitas",
    description: "Area taman dengan menara pandang dan halaman asri di dalam kompleks Ma'had."
  },
  {
    src: "/images/gmaps/lahan-pertanian-lereng.webp",
    title: "Lahan Pertanian Lereng",
    category: "kemandirian",
    description: "Petak pertanian di lereng perbukitan yang digarap untuk melatih kemandirian dan kecintaan pada alam."
  }
];
---

<Layout title="Galeri Kegiatan & Fasilitas - Ma'had Nurul Haromain Lin Nisa'" description="Galeri foto otentik fasilitas, lingkungan alam, dan program kemandirian pangan Ma'had Nurul Haromain Lin Nisa' di Pujon, Malang.">
    <!-- Hero -->
    <div class="relative pt-32 pb-20 bg-primary text-white text-center overflow-hidden">
        <div class="absolute inset-0 opacity-10 bg-[radial-gradient(circle_at_top,_white,_transparent_60%)]"></div>
        <div class="relative max-w-2xl mx-auto px-6">
            <span class="inline-flex items-center gap-2 text-xs font-semibold tracking-widest uppercase bg-gold/15 border border-gold/30 text-gold px-4 py-1.5 rounded-full mb-5">
                <MapPin class="w-3.5 h-3.5" /> Ngroto · Pujon · Malang
            </span>
            <h1 class="font-heading text-4xl md:text-5xl font-bold mb-4">Galeri Ma'had</h1>
            <p class="text-white/80 text-sm md:text-base leading-relaxed">Dokumentasi otentik fasilitas, lingkungan pegunungan yang asri, dan program kemandirian pangan di lingkungan pesantren.</p>
        </div>
    </div>

    <section class="py-16 md:py-20 bg-white">
        <div class="max-w-7xl mx-auto px-6 md:px-12">
            <!-- Filter Tabs -->
            <div class="flex flex-wrap justify-center gap-3 mb-12">
                {categories.map((c) => (
                    <button
                        data-filter={c.id}
                        class={`filter-btn px-6 py-2.5 rounded-full border text-sm font-medium transition-all duration-300 cursor-pointer ${
                            c.id === "all"
                            ? "bg-primary text-white border-primary shadow-sm"
                            : "bg-background text-muted border-border/50 hover:border-gold/50 hover:text-primary"
                        }`}
                    >
                        {c.name}
                    </button>
                ))}
            </div>

            <!-- Masonry Gallery -->
            <div class="columns-1 sm:columns-2 lg:columns-3 gap-6 [column-fill:_balance] max-w-7xl mx-auto" id="gallery-grid">
                {galleryItems.map((g, i) => (
                    <button
                        type="button"
                        data-category={g.category}
                        data-index={i}
                        data-src={g.src}
                        data-title={g.title}
                        data-desc={g.description}
                        data-label={categoryLabel[g.category]}
                        class="gallery-item group block w-full text-left break-inside-avoid mb-6 bg-background rounded-3xl overflow-hidden border border-border/50 shadow-sm hover:shadow-premium-hover hover:border-gold/30 transition-all duration-500 reveal active cursor-pointer"
                    >
                        <div class="relative overflow-hidden">
                            <img
                                src={g.src}
                                alt={g.title}
                                width="600"
                                height="450"
                                loading={i < 3 ? "eager" : "lazy"}
                                decoding="async"
                                class="w-full h-auto object-cover group-hover:scale-105 transition-transform duration-700"
                            >
                            <div class="absolute inset-0 bg-gradient-to-t from-primary/85 via-primary/10 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500 flex items-end p-6">
                                <div class="w-full flex items-center justify-between text-white">
                                    <span class="text-[10px] font-semibold tracking-wider uppercase bg-gold/20 backdrop-blur-sm border border-gold/30 px-3 py-1 rounded-full">
                                        {categoryLabel[g.category]}
                                    </span>
                                    <span class="w-9 h-9 rounded-full bg-white/20 backdrop-blur-sm flex items-center justify-center border border-white/30">
                                        <ZoomIn class="w-4 h-4" />
                                    </span>
                                </div>
                            </div>
                        </div>
                        <div class="p-5 border-t border-border/30 bg-white">
                            <h3 class="font-heading text-base font-bold text-primary mb-1.5 leading-tight">{g.title}</h3>
                            <p class="text-xs text-muted leading-relaxed">{g.description}</p>
                        </div>
                    </button>
                ))}
            </div>

            <!-- Empty state -->
            <p id="empty-state" class="hidden text-center text-muted text-sm py-16">Belum ada foto pada kategori ini.</p>
        </div>
    </section>

    <!-- Lightbox -->
    <div id="lightbox" class="fixed inset-0 z-[100] hidden items-center justify-center bg-primary/95 backdrop-blur-sm p-4 md:p-8">
        <button id="lb-close" aria-label="Tutup" class="absolute top-5 right-5 w-11 h-11 rounded-full bg-white/10 hover:bg-white/20 border border-white/20 flex items-center justify-center text-white transition-colors cursor-pointer">
            <X class="w-5 h-5" />
        </button>
        <button id="lb-prev" aria-label="Sebelumnya" class="absolute left-3 md:left-8 top-1/2 -translate-y-1/2 w-11 h-11 rounded-full bg-white/10 hover:bg-white/20 border border-white/20 flex items-center justify-center text-white transition-colors cursor-pointer">
            <ChevronLeft class="w-6 h-6" />
        </button>
        <button id="lb-next" aria-label="Berikutnya" class="absolute right-3 md:right-8 top-1/2 -translate-y-1/2 w-11 h-11 rounded-full bg-white/10 hover:bg-white/20 border border-white/20 flex items-center justify-center text-white transition-colors cursor-pointer">
            <ChevronRight class="w-6 h-6" />
        </button>
        <figure class="max-w-5xl w-full flex flex-col items-center">
            <img id="lb-img" src="" alt="" class="max-h-[78vh] w-auto rounded-2xl shadow-2xl object-contain">
            <figcaption class="mt-5 text-center text-white max-w-xl">
                <span id="lb-label" class="inline-block text-[10px] font-semibold tracking-wider uppercase bg-gold/20 border border-gold/30 text-gold px-3 py-1 rounded-full mb-2"></span>
                <h3 id="lb-title" class="font-heading text-lg font-bold"></h3>
                <p id="lb-desc" class="text-sm text-white/70 mt-1.5 leading-relaxed"></p>
            </figcaption>
        </figure>
    </div>

    <PPDB />

    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const filterBtns = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
            const items = Array.from(document.querySelectorAll<HTMLElement>('.gallery-item'));
            const emptyState = document.getElementById('empty-state');

            // --- Filtering ---
            filterBtns.forEach(btn => {
                btn.addEventListener('click', () => {
                    const filter = btn.getAttribute('data-filter');
                    filterBtns.forEach(b => {
                        b.classList.remove('bg-primary', 'text-white', 'border-primary', 'shadow-sm');
                        b.classList.add('bg-background', 'text-muted', 'border-border/50');
                    });
                    btn.classList.remove('bg-background', 'text-muted', 'border-border/50');
                    btn.classList.add('bg-primary', 'text-white', 'border-primary', 'shadow-sm');

                    let visible = 0;
                    items.forEach(item => {
                        const match = filter === 'all' || item.getAttribute('data-category') === filter;
                        item.classList.toggle('hidden', !match);
                        if (match) visible++;
                    });
                    emptyState?.classList.toggle('hidden', visible !== 0);
                });
            });

            // --- Lightbox ---
            const lb = document.getElementById('lightbox')!;
            const lbImg = document.getElementById('lb-img') as HTMLImageElement;
            const lbTitle = document.getElementById('lb-title')!;
            const lbDesc = document.getElementById('lb-desc')!;
            const lbLabel = document.getElementById('lb-label')!;
            let current = 0;

            const visibleItems = () => items.filter(i => !i.classList.contains('hidden'));

            const render = () => {
                const el = visibleItems()[current];
                if (!el) return;
                lbImg.src = el.getAttribute('data-src') || '';
                lbImg.alt = el.getAttribute('data-title') || '';
                lbTitle.textContent = el.getAttribute('data-title') || '';
                lbDesc.textContent = el.getAttribute('data-desc') || '';
                lbLabel.textContent = el.getAttribute('data-label') || '';
            };
            const open = (el: HTMLElement) => {
                current = visibleItems().indexOf(el);
                render();
                lb.classList.remove('hidden');
                lb.classList.add('flex');
                document.body.style.overflow = 'hidden';
            };
            const close = () => {
                lb.classList.add('hidden');
                lb.classList.remove('flex');
                document.body.style.overflow = '';
            };
            const move = (dir: number) => {
                const list = visibleItems();
                current = (current + dir + list.length) % list.length;
                render();
            };

            items.forEach(item => item.addEventListener('click', () => open(item)));
            document.getElementById('lb-close')?.addEventListener('click', close);
            document.getElementById('lb-prev')?.addEventListener('click', () => move(-1));
            document.getElementById('lb-next')?.addEventListener('click', () => move(1));
            lb.addEventListener('click', (e) => { if (e.target === lb) close(); });
            document.addEventListener('keydown', (e) => {
                if (lb.classList.contains('hidden')) return;
                if (e.key === 'Escape') close();
                if (e.key === 'ArrowRight') move(1);
                if (e.key === 'ArrowLeft') move(-1);
            });
        });
    </script>
</Layout>
