---
import Layout from '../layouts/Layout.astro';
import PPDB from '../components/PPDB.astro';
import { Camera, ZoomIn } from '@lucide/astro';

const categories = [
  { id: "all", name: "Semua Foto" },
  { id: "kegiatan", name: "Kegiatan Belajar" },
  { id: "fasilitas", name: "Fasilitas Kampus" },
  { id: "kebersamaan", name: "Kebersamaan Santri" },
  { id: "ekstra", name: "Ekstrakurikuler" }
];

const galleryItems = [
  {
    src: "/images/history-building.jpg",
    title: "Gedung Utama Ma'had",
    category: "fasilitas",
    description: "Arsitektur kubah hijau khas Ma'had dengan latar belakang pegunungan Pujon yang asri."
  },
  {
    src: "/images/scraped/mahad-scraped-3.jpg",
    title: "Kajian Kitab Diniyah",
    category: "kegiatan",
    description: "Suasana santriwati menyimak kajian kitab turats fiqih wanita bersama ustazah."
  },
  {
    src: "/images/scraped/mahad-scraped-4.jpg",
    title: "Qiyamul Lail Berjamaah",
    category: "kegiatan",
    description: "Kekhusyukan santriwati dalam pembinaan ibadah malam shalat tahajud berjamaah di masjid."
  },
  {
    src: "/images/about-library.jpg",
    title: "Perpustakaan & Ruang Kitab",
    category: "fasilitas",
    description: "Sudut membaca dengan ribuan koleksi kitab kuning klasik dan literatur sains umum."
  },
  {
    src: "/images/scraped/mahad-scraped-5.jpg",
    title: "Momen Wisuda Santriwati",
    category: "kebersamaan",
    description: "Kebersamaan wisuda kelulusan santriwati madrasah diniyah bersama dewan guru."
  },
  {
    src: "/images/boarding-activities.jpg",
    title: "Belajar Kelompok Terbuka",
    category: "kebersamaan",
    description: "Santriwati berdiskusi materi pelajaran di area taman terbuka yang sejuk dan asri."
  },
  {
    src: "/images/scraped/mahad-scraped-6.jpg",
    title: "Praktik Mengajar TPQ",
    category: "ekstra",
    description: "Bentuk pengabdian santriwati mengajar langsung baca tulis Al-Qur'an anak-anak di dusun sekitar."
  },
  {
    src: "/images/about-santriwati.jpg",
    title: "Hafalan Al-Qur'an Intensif",
    category: "kegiatan",
    description: "Santriwati fokus menghafalkan Al-Qur'an secara mandiri di serambi masjid."
  },
  {
    src: "/images/scraped/mahad-scraped-7.jpg",
    title: "Kreativitas Desain Busana",
    category: "ekstra",
    description: "Praktik merancang pola dan menjahit busana muslimah sebagai bekal wirausaha kelak."
  },
  {
    src: "/images/scraped/mahad-scraped-10.jpg",
    title: "Praktik Tani Vertikultur (TETRIS)",
    category: "ekstra",
    description: "Santriwati merawat sayur mayur organik pada paralon vertikultur program kemandirian pangan."
  },
  {
    src: "/images/cta-mosque.jpg",
    title: "Serambi Masjid Baitul Haromain",
    category: "fasilitas",
    description: "Keindahan marmer dan tiang lengkung masjid yang menjadi pusat tarbiyah santriwati."
  }
];
---

<Layout title="Galeri Kegiatan & Fasilitas - Ma'had Nurul Haromain Lin Nisa'" description="Galeri foto otentik kegiatan belajar, sarana prasarana asrama, aktivitas kebersamaan, dan program ekstrakurikuler di Pujon, Malang.">
    <!-- Subpage Hero Banner -->
    <div class="relative pt-32 pb-16 md:pt-40 md:pb-24 bg-primary text-white overflow-hidden text-center">
        <!-- Background Image with deep tint overlay -->
        <img src="/images/scraped/mahad-scraped-2.jpg" alt="Galeri Kegiatan" class="absolute inset-0 w-full h-full object-cover filter brightness-[0.25] contrast-[1.05] pointer-events-none">
        
        <!-- Subtle dark green gradient blend -->
        <div class="absolute inset-0 bg-gradient-to-b from-primary/30 via-primary/80 to-primary pointer-events-none"></div>

        <div class="relative z-10 max-w-4xl mx-auto px-6">
            <!-- Breadcrumbs -->
            <nav class="flex justify-center items-center gap-2 mb-4 text-xs font-semibold text-white/60">
                <a href="/" class="hover:text-gold transition-colors">Beranda</a>
                <span class="text-white/30">/</span>
                <span class="text-gold">Galeri Kegiatan</span>
            </nav>
            
            <h1 class="font-heading text-3xl md:text-5xl font-bold mb-3 md:mb-4 leading-tight">Galeri Kegiatan</h1>
            <p class="text-white/80 max-w-xl mx-auto text-xs md:text-sm leading-relaxed">Kilas visual dokumentasi kehidupan sehari-hari, sarana belajar, dan momen kebersamaan di pondok pesantren.</p>
        </div>
    </div>

    <section class="py-20 bg-white">
        <div class="max-w-7xl mx-auto px-6 md:px-12">
            <!-- Filter Tabs -->
            <div class="flex flex-wrap justify-center gap-3 mb-12">
                {categories.map((c) => (
                    <button 
                        data-filter={c.id}
                        class={`filter-btn px-6 py-2.5 rounded-full border text-sm font-medium transition-all duration-300 cursor-pointer ${
                            c.id === "all" 
                            ? "bg-primary text-white border-primary shadow-sm" 
                            : "bg-background text-muted border-border/50 hover:border-gold/50 hover:text-primary"
                        }`}
                    >
                        {c.name}
                    </button>
                ))}
            </div>

            <!-- Masonry Gallery Collage (Staggered Grid) -->
            <div class="columns-1 sm:columns-2 lg:columns-3 xl:columns-4 gap-6 [column-fill:_auto] max-w-7xl mx-auto" id="gallery-grid">
                {galleryItems.map((g) => (
                    <div 
                        data-category={g.category}
                        class="gallery-item break-inside-avoid mb-6 bg-background rounded-3xl overflow-hidden border border-border/50 shadow-sm hover:shadow-premium-hover hover:border-gold/30 transition-all duration-500 flex flex-col justify-between reveal active group"
                    >
                        <!-- Image Container with Zoom & Hover Effects -->
                        <div class="relative overflow-hidden cursor-pointer aspect-auto">
                            <img src={g.src} alt={g.title} class="w-full h-auto object-cover group-hover:scale-105 transition-transform duration-700 pointer-events-none">
                            <!-- Premium Image Overlay -->
                            <div class="absolute inset-0 bg-gradient-to-t from-primary/80 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500 flex items-end p-6">
                                <div class="w-full flex items-center justify-between text-white">
                                    <span class="text-xs font-semibold tracking-wider uppercase bg-gold/20 backdrop-blur-sm border border-gold/30 px-3 py-1 rounded-full">
                                        {g.category === "kegiatan" ? "Belajar" : g.category === "fasilitas" ? "Fasilitas" : g.category === "kebersamaan" ? "Kebersamaan" : "Ekstrakurikuler"}
                                    </span>
                                    <div class="w-8 h-8 rounded-full bg-white/20 backdrop-blur-sm flex items-center justify-center border border-white/30">
                                        <ZoomIn class="w-4 h-4" />
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Card Meta Info -->
                        <div class="p-6 border-t border-border/30 bg-white">
                            <h3 class="font-heading text-lg font-bold text-primary mb-2 leading-tight">{g.title}</h3>
                            <p class="text-xs text-muted leading-relaxed">{g.description}</p>
                        </div>
                    </div>
                ))}
            </div>
        </div>
    </section>

    <PPDB />

    <!-- Interactive Filtering Script -->
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const filterBtns = document.querySelectorAll('.filter-btn');
            const galleryItems = document.querySelectorAll('.gallery-item');

            filterBtns.forEach(btn => {
                btn.addEventListener('click', () => {
                    const filterValue = btn.getAttribute('data-filter');

                    // Highlight active button
                    filterBtns.forEach(b => {
                        b.classList.remove('bg-primary', 'text-white', 'border-primary', 'shadow-sm');
                        b.classList.add('bg-background', 'text-muted', 'border-border/50');
                    });
                    btn.classList.remove('bg-background', 'text-muted', 'border-border/50');
                    btn.classList.add('bg-primary', 'text-white', 'border-primary', 'shadow-sm');

                    // Filter items with transition
                    galleryItems.forEach(item => {
                        const category = item.getAttribute('data-category');
                        if (filterValue === 'all' || category === filterValue) {
                            item.classList.remove('hidden');
                            // Delay slightly for smooth transition
                            setTimeout(() => {
                                (item as HTMLElement).style.opacity = '1';
                                (item as HTMLElement).style.transform = 'scale(1)';
                            }, 50);
                        } else {
                            (item as HTMLElement).style.opacity = '0';
                            (item as HTMLElement).style.transform = 'scale(0.95)';
                            setTimeout(() => {
                                item.classList.add('hidden');
                            }, 300);
                        }
                    });
                });
            });
        });
    </script>
</Layout>
