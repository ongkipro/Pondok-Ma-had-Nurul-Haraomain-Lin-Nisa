---
import Layout from '../layouts/Layout.astro';
import PPDB from '../components/PPDB.astro';
import { Camera } from '@lucide/astro';

const categories = [
  { id: "all", name: "Semua Foto" },
  { id: "kegiatan", name: "Kegiatan Belajar" },
  { id: "fasilitas", name: "Fasilitas Kampus" },
  { id: "kebersamaan", name: "Kebersamaan Santri" },
  { id: "ekstra", name: "Ekstrakurikuler" }
];

const galleryPlaceholders = [
  {
    title: "Kajian Kitab Kuning Sore Hari",
    category: "kegiatan",
    description: "Santriwati mengkaji kitab fiqih wanita bersama ustazah di pendopo."
  },
  {
    title: "Praktik Laboratorium Komputer SMK",
    category: "kegiatan",
    description: "Praktik perakitan jaringan telekomunikasi dan pemrograman dasar."
  },
  {
    title: "Kamar Tidur Asrama Putri",
    category: "fasilitas",
    description: "Kondisi kamar tidur asrama putri yang rapi, bersih, dan berudara sejuk."
  },
  {
    title: "Klinik Medis Pratama",
    category: "fasilitas",
    description: "Fasilitas klinik kesehatan khusus santriwati di komplek ma'had."
  },
  {
    title: "Makan Bersama (Mayoritas) Santri",
    category: "kebersamaan",
    description: "Tradisi makan bersama talam sebagai wujud ukhuwah islamiyah."
  },
  {
    title: "Praktik Vertikultur Sayur TETRIS",
    category: "ekstra",
    description: "Santriwati menanam sayuran organik menggunakan paralon vertikultur."
  },
  {
    title: "Latihan Pidato Tiga Bahasa",
    category: "ekstra",
    description: "Kegiatan Tadribur Muhadloroh mingguan berbahasa Arab, Inggris, & Indonesia."
  },
  {
    title: "Kunjungan Ziarah Masyayikh",
    category: "kebersamaan",
    description: "Dokumentasi kunjungan dan doa bersama dengan para masyayikh."
  }
];
---

<Layout title="Galeri Kegiatan & Fasilitas - Ma'had Nurul Haromain Lin Nisa'" description="Dokumentasi foto kegiatan belajar mengajar, sarana prasarana asrama, aktivitas kebersamaan santriwati, dan program ekstrakurikuler di Pujon, Malang.">
    <div class="pt-24 bg-primary text-white text-center py-16">
        <h1 class="font-heading text-4xl md:text-5xl font-bold mb-4">Galeri Kegiatan</h1>
        <p class="text-white/80 max-w-xl mx-auto text-sm md:text-base">Kilas visual kehidupan sehari-hari, sarana belajar, dan momen kebersamaan di pondok pesantren.</p>
    </div>

    <section class="py-20 bg-white">
        <div class="max-w-7xl mx-auto px-6 md:px-12">
            <!-- Filter Tabs -->
            <div class="flex flex-wrap justify-center gap-3 mb-12">
                {categories.map((c) => (
                    <button 
                        data-filter={c.id}
                        class={`filter-btn px-6 py-2.5 rounded-full border text-sm font-medium transition-all duration-300 ${
                            c.id === "all" 
                            ? "bg-primary text-white border-primary shadow-sm" 
                            : "bg-background text-muted border-border/50 hover:border-gold/50 hover:text-primary"
                        }`}
                    >
                        {c.name}
                    </button>
                ))}
            </div>

            <!-- Gallery Grid -->
            <div class="grid sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6 max-w-7xl mx-auto" id="gallery-grid">
                {galleryPlaceholders.map((g) => (
                    <div 
                        data-category={g.category}
                        class="gallery-item bg-background rounded-3xl overflow-hidden border border-border/50 shadow-sm hover:shadow-premium-hover hover:border-gold/30 transition-all duration-500 flex flex-col justify-between reveal active group"
                    >
                        <!-- Photo Placeholder -->
                        <div class="aspect-[4/3] bg-primary/5 flex flex-col items-center justify-center text-gold/60 border-b border-border/30 relative overflow-hidden">
                            <!-- Background decorative mesh -->
                            <div class="absolute inset-0 bg-radial-gradient from-transparent to-primary/5 opacity-40"></div>
                            
                            <Camera class="w-10 h-10 mb-3 group-hover:scale-110 transition-transform duration-300" />
                            <span class="text-xs uppercase tracking-widest font-semibold text-primary/50">Foto Belum Diunggah</span>
                        </div>
                        <!-- Meta Info -->
                        <div class="p-6">
                            <span class="inline-block px-2.5 py-0.5 rounded-full bg-gold/10 text-gold text-xs font-semibold uppercase mb-3 border border-gold/10">
                                {g.category === "kegiatan" ? "Belajar" : g.category === "fasilitas" ? "Fasilitas" : g.category === "kebersamaan" ? "Kebersamaan" : "Ekstrakurikuler"}
                            </span>
                            <h3 class="font-heading text-lg font-bold text-primary mb-2 leading-tight">{g.title}</h3>
                            <p class="text-xs text-muted leading-relaxed">{g.description}</p>
                        </div>
                    </div>
                ))}
            </div>
        </div>
    </section>

    <PPDB />

    <!-- Interactive Filtering Script -->
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const filterBtns = document.querySelectorAll('.filter-btn');
            const galleryItems = document.querySelectorAll('.gallery-item');

            filterBtns.forEach(btn => {
                btn.addEventListener('click', () => {
                    const filterValue = btn.getAttribute('data-filter');

                    // Highlight active button
                    filterBtns.forEach(b => {
                        b.classList.remove('bg-primary', 'text-white', 'border-primary', 'shadow-sm');
                        b.classList.add('bg-background', 'text-muted', 'border-border/50');
                    });
                    btn.classList.remove('bg-background', 'text-muted', 'border-border/50');
                    btn.classList.add('bg-primary', 'text-white', 'border-primary', 'shadow-sm');

                    // Filter items
                    galleryItems.forEach(item => {
                        const category = item.getAttribute('data-category');
                        if (filterValue === 'all' || category === filterValue) {
                            item.classList.remove('hidden');
                            setTimeout(() => {
                                (item as HTMLElement).style.opacity = '1';
                                (item as HTMLElement).style.transform = 'scale(1)';
                            }, 50);
                        } else {
                            (item as HTMLElement).style.opacity = '0';
                            (item as HTMLElement).style.transform = 'scale(0.95)';
                            setTimeout(() => {
                                item.classList.add('hidden');
                            }, 300);
                        }
                    });
                });
            });
        });
    </script>
</Layout>
