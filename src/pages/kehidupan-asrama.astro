---
import Layout from '../layouts/Layout.astro';
import BoardingLife from '../components/BoardingLife.astro';
import Stats from '../components/Stats.astro';
import Testimonials from '../components/Testimonials.astro';
import PPDB from '../components/PPDB.astro';
import { Home, Shield, Laptop, Scissors, BookOpen, HeartPulse } from '@lucide/astro';

const facilities = [
  {
    title: "Asrama Nyaman & Kondusif",
    description: "Kamar tidur bersih berkapasitas teratur, berudara sejuk alami pegunungan Pujon, dilengkapi kasur, lemari pribadi, dan sirkulasi udara optimal.",
    icon: Home
  },
  {
    title: "Klinik Medis Khusus Putri",
    description: "Fasilitas pelayanan kesehatan mandiri di lingkungan pondok dengan tenaga medis perempuan standby demi menjaga kenyamanan dan privasi santriwati.",
    icon: HeartPulse
  },
  {
    title: "Laboratorium Komputer & TJKT",
    description: "Laboratorium dengan komputer berspesifikasi tinggi, akses internet serat optik, dan perangkat jaringan untuk penunjang praktik produktif.",
    icon: Laptop
  },
  {
    title: "Bengkel Desain Busana",
    description: "Ruang praktik khusus menjahit yang dilengkapi mesin jahit industri, meja pola, manekin, dan studio perancangan busana bagi program keterampilan.",
    icon: Scissors
  },
  {
    title: "Perpustakaan Kitab & Sains",
    description: "Koleksi lengkap kitab turats (kitab kuning), buku pelajaran umum, ensiklopedia sains, serta area membaca mandiri yang hening dan tenang.",
    icon: BookOpen
  },
  {
    title: "Sistem Keamanan Terpadu",
    description: "Gerbang asrama tunggal (single-gate system) khusus putri, dipagari tinggi, dengan pengawasan murabbiyah (ustazah pembimbing) 24 jam penuh.",
    icon: Shield
  }
];
---

<Layout title="Kehidupan Asrama & Fasilitas - Ma'had Nurul Haromain Lin Nisa'" description="Kehidupan sehari-hari santriwati, agenda kegiatan ibadah dan belajar harian, serta fasilitas sarana prasarana asrama putri premium di Pujon, Malang.">
    <!-- Subpage Hero Banner -->
    <div class="relative pt-32 pb-16 md:pt-40 md:pb-24 bg-primary text-white overflow-hidden text-center">
        <!-- Background Image with deep tint overlay -->
        <img src="/images/kegiatan-asrama-santriwati.webp" alt="Kehidupan Asrama Putri Ma'had Nurul Haromain" class="absolute inset-0 w-full h-full object-cover filter brightness-[0.25] contrast-[1.05] pointer-events-none" width="1920" height="400" fetchpriority="high" decoding="sync">
        
        <!-- Subtle dark green gradient blend -->
        <div class="absolute inset-0 bg-gradient-to-b from-primary/30 via-primary/80 to-primary pointer-events-none"></div>

        <div class="relative z-10 max-w-4xl mx-auto px-6">
            <!-- Breadcrumbs -->
            <nav class="flex justify-center items-center gap-2 mb-4 text-xs font-semibold text-white/60">
                <a href="/" class="hover:text-gold transition-colors">Beranda</a>
                <span class="text-white/30">/</span>
                <span class="text-gold">Kehidupan Asrama</span>
            </nav>
            
            <h1 class="font-heading text-3xl md:text-5xl font-bold mb-3 md:mb-4 leading-tight">Kehidupan Asrama</h1>
            <p class="text-white/80 max-w-xl mx-auto text-xs md:text-sm leading-relaxed">Membentuk kebiasaan ibadah yang disiplin, adab akhlak mulia, kemandirian, dan ukhuwah islamiyah.</p>
        </div>
    </div>
    
    <BoardingLife />

    <!-- Dedicated Facilities Section -->
    <section class="py-12 md:py-24 bg-white border-t border-border/10 md:border-border/30">
        <div class="max-w-7xl mx-auto px-6 md:px-12">
            <div class="text-left md:text-center max-w-2xl mx-auto mb-10 md:mb-16 reveal">
                <span class="text-gold font-semibold text-xs md:text-sm tracking-widest uppercase mb-3 block">Sarana & Prasarana</span>
                <h2 class="font-heading text-3xl md:text-4xl text-primary mb-4 md:mb-6">Fasilitas Utama Ma'had</h2>
                <p class="text-muted text-sm md:text-base">Dukungan infrastruktur belajar dan tempat tinggal yang bersih, aman, dan memadai untuk menunjang fokus pendidikan.</p>
            </div>

            <!-- Mobile View: Flat list rows (No cards) -->
            <div class="block md:hidden space-y-6 reveal">
                {facilities.map((f) => {
                    const IconComp = f.icon;
                    return (
                        <div class="flex gap-4 border-b border-border/10 pb-5 last:border-0 last:pb-0">
                            <div class="w-10 h-10 rounded-xl bg-primary/10 text-primary flex items-center justify-center shrink-0">
                                <IconComp class="w-5 h-5" />
                            </div>
                            <div>
                                <h3 class="font-heading text-base font-bold text-primary mb-1.5 leading-tight">{f.title}</h3>
                                <p class="text-xs text-muted leading-relaxed">{f.description}</p>
                            </div>
                        </div>
                    );
                })}
            </div>

            <!-- Desktop View: Card Grid -->
            <div class="hidden md:grid md:grid-cols-2 lg:grid-cols-3 gap-8 max-w-6xl mx-auto reveal">
                {facilities.map((f) => {
                    const IconComp = f.icon;
                    return (
                        <div class="bg-background rounded-2xl p-8 border border-border/50 shadow-sm hover:shadow-premium-hover transition-all duration-300 transform hover:-translate-y-1 flex flex-col justify-between">
                            <div>
                                <div class="w-12 h-12 bg-white rounded-xl flex items-center justify-center text-gold mb-6 border border-border shadow-sm">
                                    <IconComp class="w-6 h-6" />
                                </div>
                                <h3 class="font-heading text-xl font-bold text-primary mb-3 leading-tight">{f.title}</h3>
                                <p class="text-sm text-muted leading-relaxed">{f.description}</p>
                            </div>
                        </div>
                    );
                })}
            </div>
        </div>
    </section>

    <Stats />
    <Testimonials />
    <PPDB />
</Layout>
