---
import Layout from '../layouts/Layout.astro';
import Programs from '../components/Programs.astro';
import Keterampilan from '../components/Keterampilan.astro';
import Highlights from '../components/Highlights.astro';
import PPDB from '../components/PPDB.astro';
---

<Layout title="Kurikulum & Program Pendidikan - Ma'had Nurul Haromain Lin Nisa'" description="Kurikulum terpadu diniyah salafiyah, tahfidz Al-Qur'an bersanad, sekolah formal MA, SMK Telekomunikasi & Tata Busana, serta program kemandirian santriwati.">
    <!-- Subpage Hero Banner -->
    <div class="relative pt-32 pb-16 md:pt-40 md:pb-24 bg-primary text-white overflow-hidden text-center">
        <!-- Background Image with deep tint overlay -->
        <img src="/images/perpustakaan-mahad-putri.webp" alt="Perpustakaan Ma'had Nurul Haromain Lin Nisa" class="absolute inset-0 w-full h-full object-cover filter brightness-[0.25] contrast-[1.05] pointer-events-none" width="1920" height="400" fetchpriority="high" decoding="sync">
        
        <!-- Subtle dark green gradient blend -->
        <div class="absolute inset-0 bg-gradient-to-b from-primary/30 via-primary/80 to-primary pointer-events-none"></div>

        <div class="relative z-10 max-w-4xl mx-auto px-6">
            <!-- Breadcrumbs -->
            <nav class="flex justify-center items-center gap-2 mb-4 text-xs font-semibold text-white/60">
                <a href="/" class="hover:text-gold transition-colors">Beranda</a>
                <span class="text-white/30">/</span>
                <span class="text-gold">Kurikulum</span>
            </nav>
            
            <h1 class="font-heading text-3xl md:text-5xl font-bold mb-3 md:mb-4 leading-tight">Kurikulum & Program</h1>
            <p class="text-white/80 max-w-xl mx-auto text-xs md:text-sm leading-relaxed">Membekali santriwati dengan ilmu salaf, hafalan quran, ijazah formal negara, & keterampilan hidup mandiri.</p>
        </div>
    </div>
    
    <Programs />
    <Keterampilan />
    <Highlights />
    <PPDB />
</Layout>
