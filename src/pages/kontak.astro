---
import Layout from '../layouts/Layout.astro';
import Contact from '../components/Contact.astro';
import PPDB from '../components/PPDB.astro';
---

<Layout title="Hubungi Kami - Ma'had Nurul Haromain Lin Nisa'" description="Kontak resmi, nomor telepon WhatsApp layanan informasi, alamat lengkap di Pujon, Malang, dan rute lokasi Google Maps Ma'had Nurul Haromain.">
    <!-- Header Banner -->
    <div class="pt-24 bg-primary text-white text-center py-16">
        <h1 class="font-heading text-4xl md:text-5xl font-bold mb-4">Hubungi Kami</h1>
        <p class="text-white/80 max-w-xl mx-auto text-sm md:text-base px-6">Sekretariat kami siap membantu menjawab pertanyaan Anda secara langsung melalui layanan WhatsApp, telepon, email, atau kunjungan langsung.</p>
    </div>

    <!-- Map & Contact Info Section -->
    <Contact />

    <!-- PPDB Section -->
    <PPDB />
</Layout>
