---
import Layout from '../layouts/Layout.astro';
import Contact from '../components/Contact.astro';
import PPDB from '../components/PPDB.astro';
---

<Layout title="Hubungi Kami - Ma'had Nurul Haromain Lin Nisa'" description="Kontak resmi, nomor telepon WhatsApp layanan informasi, alamat lengkap di Pujon, Malang, dan form kirim pesan langsung ke sekretariat.">
    <div class="pt-24 bg-primary text-white text-center py-16">
        <h1 class="font-heading text-4xl md:text-5xl font-bold mb-4">Hubungi Kami</h1>
        <p class="text-white/80 max-w-xl mx-auto text-sm md:text-base">Sekretariat kami siap membantu menjawab pertanyaan Anda seputar pendaftaran santri baru dan info pondok.</p>
    </div>

    <!-- Contact Form Section -->
    <section class="py-24 bg-white">
        <div class="max-w-4xl mx-auto px-6 md:px-12">
            <div class="bg-background rounded-3xl p-8 md:p-12 border border-border/50 shadow-premium">
                <div class="text-center mb-10">
                    <h2 class="font-heading text-3xl text-primary mb-3">Kirim Pesan Langsung</h2>
                    <p class="text-sm text-muted">Isi formulir di bawah ini untuk mengirimkan pertanyaan ke sekretariat pondok kami.</p>
                </div>

                <form class="space-y-6" onsubmit="event.preventDefault(); alert('Terima kasih! Pesan Anda telah terkirim.');">
                    <div class="grid md:grid-cols-2 gap-6">
                        <div>
                            <label class="block text-xs font-semibold text-primary uppercase mb-2 tracking-wider">Nama Lengkap</label>
                            <input type="text" required placeholder="Masukkan nama Anda" class="w-full px-4 py-3 rounded-xl border border-border bg-white text-sm focus:outline-none focus:border-gold/70 transition-colors" />
                        </div>
                        <div>
                            <label class="block text-xs font-semibold text-primary uppercase mb-2 tracking-wider">Nomor WhatsApp</label>
                            <input type="tel" required placeholder="Contoh: 08123456789" class="w-full px-4 py-3 rounded-xl border border-border bg-white text-sm focus:outline-none focus:border-gold/70 transition-colors" />
                        </div>
                    </div>

                    <div>
                        <label class="block text-xs font-semibold text-primary uppercase mb-2 tracking-wider">Alamat Email</label>
                        <input type="email" required placeholder="Contoh: nama@domain.com" class="w-full px-4 py-3 rounded-xl border border-border bg-white text-sm focus:outline-none focus:border-gold/70 transition-colors" />
                    </div>

                    <div>
                        <label class="block text-xs font-semibold text-primary uppercase mb-2 tracking-wider">Program yang Ditanyakan</label>
                        <select class="w-full px-4 py-3 rounded-xl border border-border bg-white text-sm focus:outline-none focus:border-gold/70 transition-colors">
                            <option>Madrasah Diniyyah Az-Zahra (Kitab Turats)</option>
                            <option>Madrasah Aliyah (MA) Formal</option>
                            <option>Tahfidz Daar Tanzil</option>
                            <option>SMK Nurul Haromain (TJKT & Busana)</option>
                            <option>Program Kader Guru TK (KGTK)</option>
                            <option>Lainnya / Umum</option>
                        </select>
                    </div>

                    <div>
                        <label class="block text-xs font-semibold text-primary uppercase mb-2 tracking-wider">Isi Pesan / Pertanyaan</label>
                        <textarea required rows="4" placeholder="Tuliskan pesan atau pertanyaan Anda secara rinci" class="w-full px-4 py-3 rounded-xl border border-border bg-white text-sm focus:outline-none focus:border-gold/70 transition-colors resize-none"></textarea>
                    </div>

                    <div class="text-center pt-2">
                        <button type="submit" class="inline-flex items-center justify-center px-10 py-4 rounded-full bg-primary text-white text-sm font-semibold hover:bg-primary/95 transition-all shadow-md cursor-pointer">
                            Kirim Pesan Ke Sekretariat
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </section>

    <Contact />
    <PPDB />
</Layout>
