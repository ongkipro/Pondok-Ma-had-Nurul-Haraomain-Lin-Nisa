---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title?: string;
  description?: string;
}

const { 
  title = "Ma'had Nurul Haromain Lin Nisa' | Pesantren Putri Premium & Berkualitas",
  description = "Ma'had Nurul Haromain Lin Nisa' adalah lembaga pendidikan Islam putri yang memadukan sanad keilmuan Ahlussunnah wal Jama'ah, tahfidz Al-Qur'an, dan pembinaan akhlak mulia dalam lingkungan berasrama yang aman dan nyaman."
} = Astro.props;
---

<!DOCTYPE html>
<html lang="id" class="scroll-smooth">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{title}</title>
    
    <!-- SEO & Meta Tags -->
    <meta name="description" content={description}>
    <meta name="keywords" content="pesantren putri, ma'had putri, tahfidz quran, ahlussunnah wal jamaah, pendidikan islam, asrama putri, nurul haromain, pujon, malang">
    <link rel="canonical" href="https://lin-nisa.vercel.app">
    
    <!-- Favicons & App Manifest -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg">
    <link rel="icon" type="image/x-icon" href="/favicon.ico">
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png">
    <link rel="manifest" href="/site.webmanifest">
    <meta name="theme-color" content="#123524">
    
    <!-- Open Graph -->
    <meta property="og:title" content={title}>
    <meta property="og:description" content={description}>
    <meta property="og:type" content="website">
    <meta property="og:url" content="https://lin-nisa.vercel.app">
    <meta property="og:image" content="https://lin-nisa.vercel.app/images/history-building.jpg">
    
    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content={title}>
    <meta name="twitter:description" content={description}>
    
    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=Playfair+Display:ital,wght@0,400;0,500;0,600;0,700;1,400&family=Amiri:wght@400;700&display=swap" rel="stylesheet">
    
    <!-- Schema.org JSON-LD -->
    <script type="application/ld+json" is:inline>
    {
      "@context": "https://schema.org",
      "@type": "EducationalOrganization",
      "name": "Ma'had Nurul Haromain Lin Nisa'",
      "description": "Lembaga pendidikan Islam putri premium berlandaskan Ahlussunnah wal Jama'ah.",
      "url": "https://nurulharomain-linnisa.sch.id",
      "logo": "https://nurulharomain-linnisa.sch.id/logo.png",
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "Pujon",
        "addressRegion": "Jawa Timur",
        "addressCountry": "ID"
      }
    }
    </script>
</head>
<body class="bg-background text-text-dark font-body antialiased selection:bg-gold selection:text-white overflow-x-hidden">

    <!-- Header / Navigation -->
    <Header />

    <!-- Slot for Main Content -->
    <main>
        <slot />
    </main>

    <Footer />

    <!-- Mobile Sticky Bottom Navigation (App Style Tab Bar) -->
    <div class="fixed bottom-0 left-0 right-0 bg-white/95 backdrop-blur-md border-t border-border/40 z-40 md:hidden pb-safe shadow-premium px-4 py-2">
        <div class="flex items-center justify-around text-center max-w-md mx-auto">
            <!-- Tab Home -->
            <a href="/" data-path="/" class="mobile-tab flex flex-col items-center gap-1 text-[9px] font-semibold text-muted hover:text-gold transition-colors py-1 px-3">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path><polyline points="9 22 9 12 15 12 15 22"></polyline></svg>
                <span>Beranda</span>
            </a>
            <!-- Tab Program -->
            <a href="/kurikulum" data-path="/kurikulum" class="mobile-tab flex flex-col items-center gap-1 text-[9px] font-semibold text-muted hover:text-primary transition-colors py-1 px-3">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H19a1 1 0 0 1 1 1v18a1 1 0 0 1-1 1H6.5a1 1 0 0 1 0-5H20"></path></svg>
                <span>Program</span>
            </a>
            <!-- Center Button: WhatsApp Chat (Featured Action Button) -->
            <a href="https://wa.me/6281234567890?text=Assalamualaikum%20Admin%20Nurul%20Haromain%20Lin%20Nisa,%20saya%20ingin%20bertanya%20seputar%20informasi%20pondok..." target="_blank" class="flex flex-col items-center justify-center -mt-6 bg-[#25D366] text-white w-12 h-12 rounded-full shadow-premium border-4 border-white transform hover:scale-105 active:scale-95 transition-all" aria-label="Chat WhatsApp">
                <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L0 24l6.335-1.662c1.746.953 3.71 1.455 5.703 1.456h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413"/></svg>
            </a>
            <!-- Tab Masyayikh -->
            <a href="/tentang" data-path="/tentang" class="mobile-tab flex flex-col items-center gap-1 text-[9px] font-semibold text-muted hover:text-primary transition-colors py-1 px-3">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M22 21v-2a4 4 0 0 0-3-3.87"></path><path d="M16 3.13a4 4 0 0 1 0 7.75"></path></svg>
                <span>Pengasuh</span>
            </a>
            <!-- Tab Kehidupan/Asrama -->
            <a href="/kehidupan-asrama" data-path="/kehidupan-asrama" class="mobile-tab flex flex-col items-center gap-1 text-[9px] font-semibold text-muted hover:text-primary transition-colors py-1 px-3">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 10v6M2 10l10-5 10 5-10 5z"></path><path d="M6 12v5c0 2 2 3 6 3s6-1 6-3v-5"></path></svg>
                <span>Asrama</span>
            </a>
        </div>
    </div>

    <!-- Desktop Floating WhatsApp Button -->
    <div class="fixed bottom-6 right-6 z-40 hidden md:block group">
        <!-- Floating tooltip chat bubble -->
        <div class="absolute right-16 top-1/2 -translate-y-1/2 bg-white text-primary text-xs font-semibold px-4 py-2.5 rounded-2xl shadow-premium border border-border/30 whitespace-nowrap opacity-0 group-hover:opacity-100 transition-all duration-300 translate-x-2 group-hover:translate-x-0 pointer-events-none">
            Tanya Info Pondok? Chat Kami
            <!-- Little arrow pointing right -->
            <div class="absolute right-[-6px] top-1/2 -translate-y-1/2 w-3 h-3 bg-white border-r border-t border-border/30 rotate-45"></div>
        </div>
        
        <!-- Main WhatsApp Button -->
        <a href="https://wa.me/6281234567890?text=Assalamualaikum%20Admin%20Nurul%20Haromain%20Lin%20Nisa,%20saya%20ingin%20bertanya%20seputar%20informasi%20pondok..." target="_blank" class="flex items-center justify-center bg-[#25D366] text-white w-14 h-14 rounded-full shadow-premium hover:shadow-premium-hover transform hover:scale-105 active:scale-95 transition-all duration-300 relative" aria-label="Chat WhatsApp">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L0 24l6.335-1.662c1.746.953 3.71 1.455 5.703 1.456h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413"/></svg>
            
            <!-- Red Pulse Notification Badge -->
            <span class="absolute -top-1 -right-1 w-5 h-5 bg-red-500 rounded-full border-2 border-white flex items-center justify-center text-[10px] font-bold text-white shadow-md animate-pulse">1</span>
        </a>
    </div>

    <!-- Padding for Mobile Bottom CTA -->
    <div class="h-16 md:hidden"></div>

    <!-- JavaScript Interactions -->
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            // 1. Mobile Menu Toggle
            const mobileMenuBtn = document.getElementById('mobile-menu-btn');
            const mobileMenu = document.getElementById('mobile-menu');
            const menuIconSvg = document.getElementById('menu-icon-svg');
            const mobileMenuBackdrop = document.getElementById('mobile-menu-backdrop');
            const mobileLinks = document.querySelectorAll('.mobile-link');
            const header = document.getElementById('header');
            const logoText = header?.querySelector('.logo-text');
            const navLinks = header?.querySelectorAll('.nav-link');
            let isMenuOpen = false;

            function updateHeaderColors() {
                const isScrolled = window.scrollY > 50;
                const shouldBeDark = isScrolled || isMenuOpen;
                
                if (shouldBeDark) {
                    if (logoText) {
                        logoText.classList.remove('text-white');
                        logoText.classList.add('text-primary');
                    }
                    if (mobileMenuBtn) {
                        mobileMenuBtn.classList.remove('text-white');
                        mobileMenuBtn.classList.add('text-primary');
                    }
                    navLinks?.forEach(link => {
                        link.classList.remove('text-white/80', 'hover:text-white');
                        link.classList.add('text-text-dark', 'hover:text-gold');
                    });
                } else {
                    if (logoText) {
                        logoText.classList.remove('text-primary');
                        logoText.classList.add('text-white');
                    }
                    if (mobileMenuBtn) {
                        mobileMenuBtn.classList.remove('text-primary');
                        mobileMenuBtn.classList.add('text-white');
                    }
                    navLinks?.forEach(link => {
                        link.classList.remove('text-text-dark', 'hover:text-gold');
                        link.classList.add('text-white/80', 'hover:text-white');
                    });
                }
            }

            function toggleMenu() {
                isMenuOpen = !isMenuOpen;
                if (isMenuOpen) {
                    mobileMenu.classList.remove('-translate-y-full');
                    if (mobileMenuBackdrop) {
                        mobileMenuBackdrop.classList.remove('opacity-0', 'pointer-events-none');
                        mobileMenuBackdrop.classList.add('opacity-100', 'pointer-events-auto');
                    }
                    // Morph to X
                    if (menuIconSvg) {
                        menuIconSvg.innerHTML = '<line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line>';
                    }
                    document.body.style.overflow = 'hidden';
                } else {
                    mobileMenu.classList.add('-translate-y-full');
                    if (mobileMenuBackdrop) {
                        mobileMenuBackdrop.classList.remove('opacity-100', 'pointer-events-auto');
                        mobileMenuBackdrop.classList.add('opacity-0', 'pointer-events-none');
                    }
                    // Morph to Menu Burger
                    if (menuIconSvg) {
                        menuIconSvg.innerHTML = '<line x1="4" y1="12" x2="20" y2="12"></line><line x1="4" y1="6" x2="20" y2="6"></line><line x1="4" y1="18" x2="20" y2="18"></line>';
                    }
                    document.body.style.overflow = 'auto';
                }
                updateHeaderColors();
            }

            const closeMenuBtnInner = document.getElementById('close-menu-btn-inner');

            if (mobileMenuBtn) {
                mobileMenuBtn.addEventListener('click', toggleMenu);
            }
            if (mobileMenuBackdrop) {
                mobileMenuBackdrop.addEventListener('click', toggleMenu);
            }
            if (closeMenuBtnInner) {
                closeMenuBtnInner.addEventListener('click', toggleMenu);
            }
            mobileLinks.forEach(link => {
                link.addEventListener('click', () => {
                    if (isMenuOpen) toggleMenu();
                });
            });

            // Mobile Navigation Active States based on Pathname
            const tabs = document.querySelectorAll('.mobile-tab');
            const currentPath = window.location.pathname;
            tabs.forEach(tab => {
                const tabPath = tab.getAttribute('data-path');
                if (tabPath === '/' ? currentPath === '/' : currentPath.startsWith(tabPath)) {
                    tab.classList.add('text-primary');
                    tab.classList.remove('text-muted');
                } else {
                    tab.classList.add('text-muted');
                    tab.classList.remove('text-primary');
                }
            });

            // 2. Header Scroll Effect
            function handleScroll() {
                if (window.scrollY > 50) {
                    header.classList.add('bg-background/95', 'backdrop-blur-md', 'shadow-sm', 'border-b', 'border-border/50', 'py-3');
                    header.classList.remove('bg-transparent', 'py-4', 'is-top');
                } else {
                    header.classList.remove('bg-background/95', 'backdrop-blur-md', 'shadow-sm', 'border-b', 'border-border/50', 'py-3');
                    header.classList.add('bg-transparent', 'py-4', 'is-top');
                }
                updateHeaderColors();
            }
            handleScroll();
            window.addEventListener('scroll', handleScroll);

            // 3. Scroll Reveal Animation using Intersection Observer
            const revealElements = document.querySelectorAll('.reveal');
            
            const revealOptions = {
                threshold: 0.1,
                rootMargin: "0px 0px -50px 0px"
            };

            const revealObserver = new IntersectionObserver(function(entries, observer) {
                entries.forEach(entry => {
                    if (entry.isIntersecting) {
                        entry.target.classList.add('active');
                        observer.unobserve(entry.target); // Only animate once
                    }
                });
            }, revealOptions);

            revealElements.forEach(el => {
                revealObserver.observe(el);
            });

            // 4. Animated Counters
            const counters = document.querySelectorAll('.counter');
            let hasAnimated = false;
            
            const counterObserver = new IntersectionObserver((entries) => {
                if (entries[0].isIntersecting && !hasAnimated) {
                    hasAnimated = true;
                    counters.forEach(counter => {
                        const target = +counter.getAttribute('data-target');
                        const duration = 2000; // 2 seconds
                        const increment = target / (duration / 16); // 60fps
                        
                        let current = 0;
                        const updateCounter = () => {
                            current += increment;
                            if (current < target) {
                                counter.innerText = Math.ceil(current);
                                requestAnimationFrame(updateCounter);
                            } else {
                                counter.innerText = target;
                            }
                        };
                        updateCounter();
                    });
                }
            }, { threshold: 0.3 });

            if (counters.length > 0) {
                const triggerSection = counters[0].closest('section');
                if (triggerSection) {
                    counterObserver.observe(triggerSection);
                }
            }

            // 5. Accordion Exclusive Open (only one open at a time)
            const detailsElements = document.querySelectorAll('details');
            detailsElements.forEach((targetDetail) => {
                targetDetail.addEventListener('click', () => {
                    detailsElements.forEach((detail) => {
                        if (detail !== targetDetail) {
                            detail.removeAttribute('open');
                        }
                    });
                });
            });
        });
    </script>

    <style is:global>
        /* Header state styles when at the top of the page */
        #header.is-top .nav-link {
            color: rgba(255, 255, 255, 0.9) !important;
        }
        #header.is-top .nav-link:hover {
            color: var(--color-gold) !important;
        }
        #header.is-top .logo-text {
            color: #ffffff !important;
        }
        #header.is-top #mobile-menu-btn {
            color: #ffffff !important;
        }
        #header.is-top #nav-ppdb-btn {
            background-color: var(--color-gold) !important;
            color: var(--color-primary) !important;
        }
        #header.is-top #nav-ppdb-btn:hover {
            background-color: #ffffff !important;
            color: var(--color-primary) !important;
        }

        /* Hide scrollbars for horizontal snap-scroll rows on mobile */
        .scrollbar-none::-webkit-scrollbar {
            display: none;
        }
        .scrollbar-none {
            -ms-overflow-style: none;
            scrollbar-width: none;
        }
    </style>
</body>
</html>
